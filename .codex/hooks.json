{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/.codex/hooks/codingservices-session-start.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\VSCodeProjects\\CodingServices\\.codex\\hooks\\codingservices-session-start.ps1\"",
            "timeout": 30,
            "statusMessage": "Starting CodingServices workspace"
          }
        ]
      }
    ]
  }
}
