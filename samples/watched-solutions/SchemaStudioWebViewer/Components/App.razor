@using SchemaStudio.AIHelpers

@attribute [FileVersion("1.7")]
@attribute [AIFileContext("Components/App.razor", "Defines the root HTML shell, shared browser-side state helpers, script references, and global client behaviors for the Blazor app.")]
@attribute [AIChange("1.4", "2026-05-01 08:58 AM CDT stopped clearing session authentication on pagehide so browser refresh does not immediately log the user out.", AICommandStatus.Pending)]
@attribute [AIChange("1.3", "2026-04-22 06:06 PM CDT restored Radzen script before Blazor so dropdowns and other Radzen components initialize their JavaScript.", AICommandStatus.Pending)]
@attribute [AIChange("1.2", "2026-04-22 06:04 PM CDT loaded Radzen browser script after Blazor so shared dialog JavaScript initializes reliably.", AICommandStatus.Pending)]
@attribute [AIChange("1.1", "2026-04-22 06:02 PM CDT made global browser helpers idempotent so repeated script evaluation cannot break JavaScript.", AICommandStatus.Pending)]
@attribute [AIChange("1.0", "2026-04-22 11:51 AM CDT added session-scoped auth storage and page-unload cleanup so browser close/reload starts logged out.", AICommandStatus.Pending)]

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SUSStudio -- Schema Understanding Service</title>
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="SchemaStudioWebViewer.styles.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/standard-base.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="domainObjectEditorPanes.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-sql.min.js"></script>

    <script>
        (function () {
            // 2026-04-22 06:02 PM CDT AI v1.1 browser-helper marker: keep globals idempotent so repeated shell script evaluation cannot throw redeclaration errors.
            window.stateManager = {
                save: function (key, value) {
                    localStorage.setItem(key, value);
                },
                load: function (key) {
                    return localStorage.getItem(key);
                }
            };

            window.authStateManager = {
                save: function (key, value) {
                    sessionStorage.setItem(key, value);
                },
                load: function (key) {
                    return sessionStorage.getItem(key);
                },
                clear: function (key) {
                    sessionStorage.removeItem(key);
                },
                clearLogoutState: function () {
                    sessionStorage.removeItem("simpleAuth");
                    localStorage.removeItem("dbId");
                    localStorage.removeItem("dom");
                    localStorage.removeItem("objId");
                }
            };

            window.highlightSql = async function (maxRetries = 30) {
                if (!window.Prism) return;

                for (let i = 0; i < maxRetries; i++) {
                    const codeBlock = document.querySelector('.sql-code-container code');

                    if (codeBlock) {
                        window.Prism.highlightElement(codeBlock);
                        return;
                    }

                    await new Promise(resolve => setTimeout(resolve, 100));
                }

                console.warn("Prism highlight failed: Element not found after 30 attempts.");
            };

            window.domModeler = {
                value: function (id) {
                    const element = document.getElementById(id);
                    return element && typeof element.value === "string" ? element.value : "";
                }
            };
        })();
    </script>
</body>
</html>
