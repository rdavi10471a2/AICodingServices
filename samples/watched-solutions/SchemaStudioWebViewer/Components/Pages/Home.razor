                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    Density="Density.Compact"
                    Style="height:500px;"
                    RowDoubleClick="@(args => OpenRowDetails(args.Data))">

        <HeaderTemplate>
            <div class="section-header" style="margin-bottom:0;">
