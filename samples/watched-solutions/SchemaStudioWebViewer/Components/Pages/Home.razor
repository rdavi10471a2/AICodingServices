<style>
    .view-label-blue {
        color: var(--rz-primary) !important;
        font-weight: 400 !important;
        text-transform: uppercase !important;
        font-size: 0.75rem !important;
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 8px;
        min-height: 24px;
    }

    .metadata-scroll-box {
        background-color: #f6f8f9 !important;
        border: 1px solid #dee2e6 !important;
        border-radius: 4px;
        padding: 10px;
        height: 120px;
        overflow-y: auto;
        overflow-x: hidden;
        width: 100%;
        font-family: var(--rz-text-font-family) !important;
        font-size: 0.875rem !important;
        color: #495057;
        line-height: 1.5;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .header-text-bold {
        font-weight: 600 !important;
        color: #000 !important;
    }

    .flex-header {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .grid-wrapper {
        border: 1px solid #dee2e6;
        border-radius: 4px;
    }

    .section-header {
        color: var(--rz-primary);
        font: 14pt;
        font-weight:bold;
        margin-bottom: 12px;
       /* border-bottom: 2px solid var(--rz-primary);*/
        padding-bottom: 4px;
    }

    .login-panel {
        max-width: 420px;
        margin: 1rem auto;
    }

    .login-error {
        color: #b32121;
        font-weight: 600;
        margin-top: .5rem;
    }
</style>

@* 2026-04-23 10:10 AM CDT AI v1.9 startup-retry marker: first render now skips the duplicate database load when startup already tried and failed to populate the database list. *@
@* 2026-04-23 10:00 AM CDT AI v1.8 inline-error marker: Home now keeps a visible load-error alert on the page so failed database calls are obvious even after the toast fades. *@
@* 2026-04-23 09:51 AM CDT AI v1.7 startup-error marker: catch initial repository failures on Home and always unwind loading state so broken DB connections show a toast instead of hanging the page. *@
@* 2026-04-22 11:51 AM CDT AI v1.6 auth-session marker: simple auth uses session storage so browser close/reload/debug restart begins logged out. *@
@* 2026-04-22 11:47 AM CDT AI v1.5 login cancel marker: cancel collapses the inline login panel without disturbing the current kiosk selection. *@
@* 2026-04-22 11:43 AM CDT AI v1.4 logout redirect marker: logout clears state and returns the user to the configured kiosk route. *@
@* 2026-04-22 11:40 AM CDT AI v1.3 route/logout marker: route changes refresh auth gating and logout clears stale selected-view state. *@
@* 2026-04-22 11:30 AM CDT AI v1.2 debug autofill marker: Auth.InDebug can prefill the temporary admin credentials for local testing. *@
@* 2026-04-22 11:26 AM CDT AI v1.1 login marker: the shared Home component gates only the normal route and lets kiosk login flow return to /. *@
@* 2026-04-22 11:06 AM CDT AI v1.0 kiosk route marker: /kiosk intentionally renders the same Home workflow while MainLayout decides whether navigation chrome is shown. *@
<PageTitle>Choose View</PageTitle>

<RadzenCard Variant="Variant.Flat" Class="rz-p-2 rz-mb-2">

    <RadzenRow Class="rz-mb-2 rz-px-1">

        <RadzenColumn Size="8">
            <RadzenText TextStyle="TextStyle.Caption"
                        Style="color:#212529;font-weight:700;font-style:normal;">
                Choose a source Database, Business Domain, and view to see its details.
            </RadzenText>
        </RadzenColumn>

        <RadzenColumn Size="4">
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.End"
                         Gap="0.5rem">
                @if (!IsWaitingForAuthState)
                {
                    <RadzenButton Size="ButtonSize.Small"
                                  Variant="Variant.Text"
                                  Icon="@(IsAuthenticated ? "logout" : "login")"
                                  Text="@(IsAuthenticated ? "Logout" : "Login")"
                                  Click="@OnAuthButtonClick" />
                }
                <RadzenIcon Icon="help_outline"
                            Style="cursor:help;color:var(--rz-primary);font-size:1.25rem;"
                            @onclick="@(() => OpenHelp("system-overview"))"
                            @ondblclick="@EnterAdminMode" />
            </RadzenStack>
        </RadzenColumn>

    </RadzenRow>

    @if (CanShowHomeContent)
    {
    <RadzenRow Gap="0.5rem" AlignItems="AlignItems.Center">
@* 
        <RadzenColumn Size="12" SizeMD="2">
            <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0 header-text-bold">
                CHOOSE VIEW
            </RadzenText>
        </RadzenColumn> *@

        <RadzenColumn Size="12" SizeMD="3">
            <div class="rz-display-flex rz-align-items-center">
                <RadzenIcon Icon="info"
                            Class="rz-mr-2"
                            Style="cursor:pointer;color:var(--rz-info);"
                            @onclick="@(() => OpenHelp("explore-databases"))" />

                <RadzenDropDown Data="@Databases"
                                TextProperty="DatabaseName"
                                ValueProperty="DatabaseId"
                                Placeholder="Database"
                                @bind-Value="@SelectedDatabaseId"
                                Change="@OnDatabaseChanged"
                                Style="width:100%;"
                                AllowClear="true" />
            </div>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="3">
            <RadzenDropDown Data="@Domains"
                            TextProperty="Domain"
                            ValueProperty="Domain"
                            Placeholder="Business Domain"
                            @bind-Value="@SelectedDomain"
                            Change="@OnDomainChanged"
                            Disabled="@(!SelectedDatabaseId.HasValue)"
                            Style="width:100%;"
                            AllowClear="true" />
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="4">
            <RadzenDropDown Data="@DisplayObjects"
                            TextProperty="DisplayName"
                            ValueProperty="SchemaObjectId"
                            Placeholder="View"
                            @bind-Value="@SelectedObjectId"
                            Change="@OnObjectChanged"
                            Disabled="@string.IsNullOrWhiteSpace(SelectedDomain)"
                            Style="width:100%;"
                            AllowClear="true">

                <Template Context="obj">
                    @{
                        var item = obj as DisplaySchemaObject;
                    }

                    @if (item?.IsHeader == true)
                    {
                        <div style="font-weight:700;color:#888;background:#f5f5f5;padding:.35rem .5rem;">
                            @item.DisplayName
                        </div>
                    }
                    else
                    {
                        <div class="rz-display-flex rz-align-items-center" style="gap:.5rem;">
                            @if (item?.IsBaseObject == true)
                            {
                                <RadzenIcon Icon="layers"
                                            Style="font-size:14px;color:var(--rz-primary);" />
                            }

                            <span>@item?.DisplayName</span>
                        </div>
                    }
                </Template>
            </RadzenDropDown>
        </RadzenColumn>

    </RadzenRow>
    }
</RadzenCard>

@if (ShowLoginPanel)
{
    <RadzenCard Variant="Variant.Flat" Class="login-panel rz-p-4">
        <RadzenStack Gap="0.75rem">
            <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0">Login</RadzenText>
            <RadzenTextBox Placeholder="Username"
                           @bind-Value="@LoginUserName"
                           Style="width:100%;" />
            <input class="rz-textbox" type="password" placeholder="Password" @bind="LoginPassword" style="width:100%;" />
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.End"
                         Gap="0.5rem">
                <RadzenButton Icon="close"
                              Text="Cancel"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@CancelLogin" />
                <RadzenButton Icon="login"
                              Text="Login"
                              Click="@LoginAsync" />
            </RadzenStack>
            @if (!string.IsNullOrWhiteSpace(LoginError))
            {
                <div class="login-error">@LoginError</div>
            }
        </RadzenStack>
    </RadzenCard>
}

@if (CanShowHomeContent && !string.IsNullOrWhiteSpace(LoadError))
{
    <RadzenAlert AlertStyle="AlertStyle.Danger"
                 Variant="Variant.Flat"
                 class="rz-mb-2">
        @LoadError
    </RadzenAlert>
}

@if (CanShowHomeContent && IsLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Class="rz-mb-2" />
}

@if (CanShowHomeContent && SelectedObject != null)
{
    <div class="section-header">
        VIEW DETAILS
    </div>

    <RadzenCard Variant="Variant.Filled"
                Class="rz-mb-4 rz-p-3"
                Style="background-color:#ffffff;;"
                 >

        <RadzenRow Gap="1rem">

            <RadzenColumn Size="12" SizeMD="3">
                <div class="view-label-blue">
                    @ReflectionUtils.GetDisplayName(typeof(SchemaObjectModel), "BusinessName")
                    <RadzenIcon Icon="help_outline"
                                MouseEnter="@(args => TooltipService.Open(args,ReflectionUtils.GetDescription(typeof(SchemaObjectModel), "BusinessName")))" />
            </div>

                <RadzenText Style="font-size:14pt; font-weight:bold;">
                    @SelectedObject.BusinessName
                </RadzenText>

            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <div class="view-label-blue">
                    @ReflectionUtils.GetDisplayName(typeof(SchemaObjectModel), "BusinessDescription")
                    <RadzenIcon Icon="help_outline"
                                MouseEnter="@(args => TooltipService.Open(args,
                                                                                            ReflectionUtils.GetDescription(typeof(SchemaObjectModel), "BusinessDescription")))" />
            </div>

            <div class="metadata-scroll-box">
                @SelectedObject.BusinessDescription
            </div>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="5">
            <div class="view-label-blue">
                @ReflectionUtils.GetDisplayName(typeof(SchemaObjectModel), "DeveloperNotes")
                <RadzenIcon Icon="help_outline"
                            MouseEnter="@(args => TooltipService.Open(args,
                                                                                            ReflectionUtils.GetDescription(typeof(SchemaObjectModel), "DeveloperNotes")))" />
            </div>

            <div class="metadata-scroll-box">
                @SelectedObject.DeveloperNotes
            </div>
        </RadzenColumn>

    </RadzenRow>

</RadzenCard>

