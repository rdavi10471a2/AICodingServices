}
@code {

    private List<DatabaseModel> Databases = new();
    private List<DatabaseDomainModel> Domains = new();
    private List<DisplaySchemaObject> DisplayObjects = new();
    private List<SchemaObjectColumnModel> Columns = new();

    private int? SelectedDatabaseId;
    private string SelectedDomain = "";
    private int? SelectedObjectId;
    private int? LastValidObjectId;

    private SchemaObjectModel? SelectedObject;

    private bool IsLoading = false;
    private bool IsAuthenticated = false;
    private bool IsAuthStateLoaded = false;
    private bool IsLoginFormVisible = false;
    private string LoginUserName = "";
    private string LoginPassword = "";
    private string LoginError = "";
    private string LoadError = "";
    private bool HasAttemptedInitialDatabaseLoad = false;

    private const string AuthStorageKey = "simpleAuth";
    private const string AuthenticatedValue = "true";
    private const string AdminUserName = "admin";
    private const string AdminPassword = "admin123";

    private ReadOnlyDatabaseRepository DbRepo =
        new(AppConfig.Current.ConnectionStrings.DefaultConnection);

    private ReadOnlySchemaObjectRepository SchemaRepo =
        new(AppConfig.Current.ConnectionStrings.DefaultConnection);

    private ReadOnlyViewDefinitionRepository ViewRepo =
        new(AppConfig.Current.ConnectionStrings.DefaultConnection);

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (CanShowHomeContent)
            {
                HasAttemptedInitialDatabaseLoad = true;
                await EnsureDatabasesLoadedAsync();
            }
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Database load failed", ex);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Task.Delay(100);

        await RefreshRouteStateAsync();
    }

    private bool IsKioskRoute =>
        string.IsNullOrWhiteSpace(CurrentRelativePath) ||
        string.Equals(CurrentRelativePath, AppConfig.Current.Kiosk.Route.Trim('/'), StringComparison.OrdinalIgnoreCase);

    private bool IsNormalHomeRoute => string.Equals(CurrentRelativePath, "explore", StringComparison.OrdinalIgnoreCase);

    private bool RequiresNormalHomeAuth =>
        AppConfig.Current.Auth.Enabled &&
        AppConfig.Current.Auth.RequireLoginForHome &&
        IsNormalHomeRoute;

    private bool IsWaitingForAuthState =>
        RequiresNormalHomeAuth &&
        !IsAuthStateLoaded;

    private bool ShouldBlockNormalHome =>
        RequiresNormalHomeAuth &&
        IsAuthStateLoaded &&
        !IsAuthenticated;

    private bool ShowLoginPanel => !IsWaitingForAuthState && (IsLoginFormVisible || ShouldBlockNormalHome);

    private bool CanShowHomeContent => !IsWaitingForAuthState && !ShouldBlockNormalHome;

    private string CurrentRelativePath
    {
        get
        {
            var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var queryIndex = relative.IndexOf('?', StringComparison.Ordinal);
            return (queryIndex >= 0 ? relative[..queryIndex] : relative).Trim('/');
        }
    }

    private async Task LoadAuthStateAsync()
    {
        var authValue = await JSRuntime.InvokeAsync<string>("authStateManager.load", AuthStorageKey);
        IsAuthenticated = string.Equals(authValue, AuthenticatedValue, StringComparison.OrdinalIgnoreCase);
        IsAuthStateLoaded = true;
        IsLoginFormVisible = ShouldBlockNormalHome;
        AutofillDebugCredentials();
    }

    private async Task RefreshRouteStateAsync()
    {
        try
        {
            await LoadAuthStateAsync();

            if (!CanShowHomeContent)
            {
                ClearChildSelections();
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (!Databases.Any() && HasAttemptedInitialDatabaseLoad)
            {
                await InvokeAsync(StateHasChanged);
                return;
            }

            await EnsureDatabasesLoadedAsync();
            await LoadStateAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Home load failed", ex);
            ClearChildSelections();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task EnsureDatabasesLoadedAsync()
    {
        HasAttemptedInitialDatabaseLoad = true;
        if (!Databases.Any())
        {
            Databases = await DbRepo.GetAllAsync();
            LoadError = "";
        }
    }

    private async Task LoadStateAsync()
    {
        LoadError = "";
        var dbStr = await JSRuntime.InvokeAsync<string>("stateManager.load", "dbId");
        var dom = await JSRuntime.InvokeAsync<string>("stateManager.load", "dom");
        var objStr = await JSRuntime.InvokeAsync<string>("stateManager.load", "objId");

        if (!int.TryParse(dbStr, out var dbId))
            return;

        SelectedDatabaseId = dbId;
        Domains = await DbRepo.GetDomainsAsync(dbId);

        if (!string.IsNullOrWhiteSpace(dom))
        {
            SelectedDomain = dom;

            var raw = await SchemaRepo.GetByDatabaseAsync(dbId);

            var filtered = raw.Where(x => x.Domain == SelectedDomain)
                              .OrderByDescending(x => x.IsBaseObject)
                              .ThenBy(x => x.BusinessName)
                              .ToList();

            var baseItems = filtered.Where(x => x.IsBaseObject).ToList();
            var derivedItems = filtered.Where(x => !x.IsBaseObject).ToList();

            DisplayObjects.Clear();

            DisplayObjects.Add(new DisplaySchemaObject
            {
                SchemaObjectId = -1,
                DisplayName = "━━ BASE OBJECTS ━━",
                IsHeader = true
            });

            DisplayObjects.AddRange(baseItems.Select(x => new DisplaySchemaObject
            {
                SchemaObjectId = x.SchemaObjectId,
                DisplayName = x.BusinessName,
                IsBaseObject = true
            }));

            if (derivedItems.Any())
            {
                DisplayObjects.Add(new DisplaySchemaObject
                {
                    SchemaObjectId = -2,
                    DisplayName = "━━ DERIVED VIEWS ━━",
                    IsHeader = true
                });

                DisplayObjects.AddRange(derivedItems.Select(x => new DisplaySchemaObject
                {
                    SchemaObjectId = x.SchemaObjectId,
                    DisplayName = x.BusinessName,
                    IsBaseObject = false
                }));
            }
        }

        if (int.TryParse(objStr, out var objId) && objId > 0)
        {
            SelectedObjectId = objId;
            LastValidObjectId = objId;

            IsLoading = true;
            try
            {
                SelectedObject = await SchemaRepo.GetByIdAsync(objId);
                Columns = await SchemaRepo.GetColumnsAsync(objId);
            }
            finally
            {
                IsLoading = false;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAuthButtonClick()
    {
        if (IsAuthenticated)
        {
            await LogoutAsync();
            return;
        }

        LoginError = "";
        IsLoginFormVisible = true;
        AutofillDebugCredentials();
    }

    private void AutofillDebugCredentials()
    {
        if (!AppConfig.Current.Auth.InDebug || IsAuthenticated)
            return;

        LoginUserName = AdminUserName;
        LoginPassword = AdminPassword;
    }

    private void CancelLogin()
    {
        IsLoginFormVisible = false;
        LoginUserName = "";
        LoginPassword = "";
        LoginError = "";
    }

    private async Task LoginAsync()
    {
        if (!string.Equals(LoginUserName, AdminUserName, StringComparison.Ordinal) ||
            !string.Equals(LoginPassword, AdminPassword, StringComparison.Ordinal))
        {
            LoginError = "Invalid username or password.";
            return;
        }

        IsAuthenticated = true;
        IsAuthStateLoaded = true;
        IsLoginFormVisible = false;
        LoginError = "";
        LoginPassword = "";

        await JSRuntime.InvokeVoidAsync("authStateManager.save", AuthStorageKey, AuthenticatedValue);
        await MainLayout.NotifyAuthenticationChangedAsync();

        if (IsKioskRoute)
        {
            NavigationManager.NavigateTo("/explore");
            return;
        }

        try
        {
            await EnsureDatabasesLoadedAsync();
            await LoadStateAsync();
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Home load failed", ex);
        }
    }

    private async Task LogoutAsync()
    {
        IsAuthenticated = false;
        IsAuthStateLoaded = true;
        IsLoginFormVisible = ShouldBlockNormalHome;
        LoginUserName = "";
        LoginPassword = "";
        LoginError = "";
        ClearChildSelections();

        await ClearPersistedSelectionStateAsync();

        await JSRuntime.InvokeVoidAsync("authStateManager.clear", AuthStorageKey);
        await MainLayout.NotifyAuthenticationChangedAsync();

        NavigationManager.NavigateTo(AppConfig.Current.Kiosk.Route);
    }

    private async Task SaveStateAsync()
    {
        await JSRuntime.InvokeVoidAsync("stateManager.save", "dbId", SelectedDatabaseId?.ToString());
        await JSRuntime.InvokeVoidAsync("stateManager.save", "dom", SelectedDomain);
        await JSRuntime.InvokeVoidAsync("stateManager.save", "objId", SelectedObjectId?.ToString());
    }

    private async Task ClearPersistedSelectionStateAsync()
    {
        await JSRuntime.InvokeVoidAsync("stateManager.save", "dbId", "");
        await JSRuntime.InvokeVoidAsync("stateManager.save", "dom", "");
        await JSRuntime.InvokeVoidAsync("stateManager.save", "objId", "");
    }

    private async Task OnDatabaseChanged(object value)
    {
        if (!int.TryParse(value?.ToString(), out var dbId))
            return;

        SelectedDatabaseId = dbId;

        ClearChildSelections(true);
        LoadError = "";

        try
        {
            Domains = await DbRepo.GetDomainsAsync(dbId);
            await SaveStateAsync();
        }
        catch (Exception ex)
        {
            Domains.Clear();
            NotifyLoadFailure("Domain load failed", ex);
        }
    }

    private async Task OnDomainChanged(object value)
    {
        SelectedDomain = value?.ToString() ?? "";
        LoadError = "";

        DisplayObjects.Clear();
        SelectedObjectId = null;
        LastValidObjectId = null;
        SelectedObject = null;
        Columns.Clear();

        if (SelectedDatabaseId.HasValue &&
            !string.IsNullOrWhiteSpace(SelectedDomain))
        {
            try
            {
                var raw = await SchemaRepo.GetByDatabaseAsync(SelectedDatabaseId.Value);

                var filtered = raw.Where(x => x.Domain == SelectedDomain)
                                  .OrderByDescending(x => x.IsBaseObject)
                                  .ThenBy(x => x.BusinessName)
                                  .ToList();

                var baseItems = filtered.Where(x => x.IsBaseObject).ToList();
                var derivedItems = filtered.Where(x => !x.IsBaseObject).ToList();

                DisplayObjects.Add(new DisplaySchemaObject
                {
                    SchemaObjectId = -1,
                    DisplayName = "━━ BASE OBJECTS ━━",
                    IsHeader = true
                });

                DisplayObjects.AddRange(baseItems.Select(x => new DisplaySchemaObject
                {
                    SchemaObjectId = x.SchemaObjectId,
                    DisplayName = x.BusinessName,
                    IsBaseObject = true
                }));

                if (derivedItems.Any())
                {
                    DisplayObjects.Add(new DisplaySchemaObject
                    {
                        SchemaObjectId = -2,
                        DisplayName = "━━ DERIVED VIEWS ━━",
                        IsHeader = true
                    });

                    DisplayObjects.AddRange(derivedItems.Select(x => new DisplaySchemaObject
                    {
                        SchemaObjectId = x.SchemaObjectId,
                        DisplayName = x.BusinessName,
                        IsBaseObject = false
                    }));
                }
            }
            catch (Exception ex)
            {
                NotifyLoadFailure("Object load failed", ex);
            }
        }

        await SaveStateAsync();
    }



    private async Task OnObjectChanged(object value)
    {
        if (!int.TryParse(value?.ToString(), out var objId))
        {
            SelectedObjectId = null;
            LastValidObjectId = null;
            SelectedObject = null;
            Columns.Clear();
            await SaveStateAsync();
            return;
        }

        if (objId <= 0)
        {
            SelectedObjectId = LastValidObjectId;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SelectedObjectId = objId;
        LastValidObjectId = objId;
        LoadError = "";

        IsLoading = true;

        try
        {
            SelectedObject = await SchemaRepo.GetByIdAsync(objId);
            Columns = await SchemaRepo.GetColumnsAsync(objId);

            await SaveStateAsync();
        }
        catch (Exception ex)
        {
            SelectedObject = null;
            Columns.Clear();
            NotifyLoadFailure("Column load failed", ex);
        }
        finally
        {
            IsLoading = false;
        }
    }



    private void ClearChildSelections(bool keepDb = false)
    {
        if (!keepDb)
        {
            SelectedDatabaseId = null;
            Domains.Clear();
        }

        SelectedDomain = "";
        DisplayObjects.Clear();
        SelectedObjectId = null;
        LastValidObjectId = null;
        SelectedObject = null;
        Columns.Clear();
        LoadError = "";
    }

