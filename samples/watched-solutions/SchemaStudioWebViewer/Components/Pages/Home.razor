                                                                                                                    ReflectionUtils.GetDescription(typeof(SchemaObjectColumnModel), "SourceColumnName")))" />
                    </div>
                </HeaderTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SchemaObjectColumnModel" Property="BusinessName">
                <HeaderTemplate>
                    <div class="view-label-blue">
                        @ReflectionUtils.GetDisplayName(typeof(SchemaObjectColumnModel), "BusinessName")
                        <RadzenIcon Icon="help_outline"
                                    MouseEnter="@(args => TooltipService.Open(args,
                                                                                                                    ReflectionUtils.GetDescription(typeof(SchemaObjectColumnModel), "BusinessName")))" />
                    </div>
                </HeaderTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SchemaObjectColumnModel" Property="BusinessDescription">
                <HeaderTemplate>
                    <div class="view-label-blue">
                        @ReflectionUtils.GetDisplayName(typeof(SchemaObjectColumnModel), "BusinessDescription")
