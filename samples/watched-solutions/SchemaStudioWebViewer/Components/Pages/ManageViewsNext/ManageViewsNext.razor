<PageTitle>Manage Views</PageTitle>

<RadzenStack Gap="0.3rem"
             class="@ManageViewsNextClass"
             Style="@PaneResizeStyle"
             @onpointermove="@ResizePane"
             @onpointerup="@EndPaneResize">
    <div class="mvn-page-header">
        <h1 class="mvn-page-title">Manage Views</h1>
        <RadzenButton Text="@(IsLeftPanelHidden ? "Show View Selector" : "Hide View Selector")"
                      Icon="@(IsLeftPanelHidden ? "right_panel_open" : "left_panel_close")"
                      ButtonStyle="ButtonStyle.Light"
                      Click="@ToggleLeftPanel" />
    </div>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            @LoadError
        </RadzenAlert>
    }

    @if (IsBusy)
    {
        <div class="mvn-busy-overlay" role="status" aria-live="polite">
            <div class="mvn-busy-card">
                <span class="mvn-busy-spinner" aria-hidden="true"></span>
                <span>Loading view workspace</span>
            </div>
        </div>
    }

    <div class="@(IsLeftPanelHidden ? "mvn-shell mvn-shell-collapsed" : "mvn-shell")">
        @if (!IsLeftPanelHidden)
        {
            <aside class="mvn-selector-panel"
                   style="display:flex; flex-direction:column; min-height:0; overflow:hidden;">
                <div class="mvn-selector-header" style="flex:0 0 auto;">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">View Selector</RadzenText>
                    <RadzenButton Text="Reload"
                                  Icon="refresh"
                                  ButtonStyle="ButtonStyle.Light"
                                  title="Refreshes database choices, domains, imported views, and available candidates."
                                  Click="@ReloadDatabasesAsync"
                                  Disabled="@IsBusy"
                                  class="mvn-selector-reload-button" />
                </div>

                <div class="mvn-selector-filters" style="flex:0 0 auto;">
                    <div class="mvn-field">
                        @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.DatabaseName))
                        <RadzenDropDown Data="@Databases"
                                        TextProperty="DatabaseName"
                                        ValueProperty="DatabaseId"
                                        @bind-Value="@SelectedDatabaseId"
                                        Change="@OnDatabaseChanged"
                                        Disabled="@IsBusy"
                                        Style="width:100%;"
                                        Placeholder="Database" />
                    </div>

                    <div class="mvn-field">
                        @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.Domain))
                        <RadzenDropDown Data="@LeftFilterDomains"
                                        TextProperty="Domain"
                                        ValueProperty="Domain"
                                        @bind-Value="@SelectedDomainFilter"
                                        Change="@OnDomainFilterChanged"
                                        Disabled="@IsBusy"
                                        Style="width:100%;"
                                        AllowClear="true"
                                        Placeholder="All Domains" />
                    </div>
                </div>

                <div class="mvn-tree-scroll"
                     style="flex:1 1 auto; min-height:0; overflow:auto; overflow-x:hidden;"
                     role="tree"
                     aria-label="Views grouped by domain and type">
                    @foreach (var group in DomainTreeGroups)
                    {
                        <details class="mvn-tree-domain">
                            <summary>
                                <RadzenIcon Icon="database" />
                                <span>@group.Domain</span>
                            </summary>

                            @if (IsUnknownDomain(group.Domain))
                            {
                                @if (group.AllViews.Count == 0)
                                {
                                    <div class="mvn-tree-empty">No unclassified views</div>
                                }
                                else
                                {
                                    @foreach (var item in group.AllViews)
                                    {
                                        <button type="button"
                                                class="@GetTreeItemClass(item)"
                                                title="@item.Subtitle"
                                                disabled="@IsBusy"
                                                @onclick="@(() => OnViewSelectionChanged(item.SelectionKey))">
                                            <RadzenIcon Icon="table_view" />
                                            <span>@item.DisplayName</span>
                                        </button>
                                    }
                                }
                            }
                            else
                            {
                                <details class="mvn-tree-folder">
                                    <summary>
                                        <RadzenIcon Icon="folder" />
                                        <span>Base Views</span>
                                    </summary>
                                    @if (group.BaseViews.Count == 0)
                                    {
                                        <div class="mvn-tree-empty">No base views</div>
                                    }
                                    else
                                    {
                                        @foreach (var item in group.BaseViews)
                                        {
                                            <button type="button"
                                                    class="@GetTreeItemClass(item)"
                                                    title="@item.Subtitle"
                                                    disabled="@IsBusy"
                                                    @onclick="@(() => OnViewSelectionChanged(item.SelectionKey))">
                                                <RadzenIcon Icon="table_view" />
                                                <span>@item.DisplayName</span>
                                            </button>
                                        }
                                    }
                                </details>

                                <details class="mvn-tree-folder">
                                    <summary>
                                        <RadzenIcon Icon="folder" />
                                        <span>Composed Views</span>
                                    </summary>
                                    @if (group.ComposedViews.Count == 0)
                                    {
                                        <div class="mvn-tree-empty">No composed views</div>
                                    }
                                    else
                                    {
                                        @foreach (var item in group.ComposedViews)
                                        {
                                            <button type="button"
                                                    class="@GetTreeItemClass(item)"
                                                    title="@item.Subtitle"
                                                    disabled="@IsBusy"
                                                    @onclick="@(() => OnViewSelectionChanged(item.SelectionKey))">
                                                <RadzenIcon Icon="table_view" />
                                                <span>@item.DisplayName</span>
                                            </button>
                                        }
                                    }
                                </details>
                            }
                        </details>
                    }

                    <details class="mvn-tree-domain">
                        <summary>
                            <RadzenIcon Icon="playlist_add" />
                            <span>Available Views</span>
                        </summary>
                        @if (AvailableViewItems.Count == 0)
                        {
                            <div class="mvn-tree-empty">No available views</div>
                        }
                        else
                        {
                            @foreach (var item in AvailableViewItems)
                            {
                                <button type="button"
                                        class="@GetTreeItemClass(item)"
                                        title="@item.Subtitle"
                                        disabled="@IsBusy"
                                        @onclick="@(() => OnViewSelectionChanged(item.SelectionKey))">
                                    <RadzenIcon Icon="table_view" />
                                    <span>@item.DisplayName</span>
                                </button>
                            }
                        }
                    </details>
                </div>

                <button type="button"
                        class="mvn-height-resize-handle"
                        title="Resize view selector height"
                        aria-label="Resize view selector height"
                        @onpointerdown="@(args => BeginPaneResize(ResizeTarget.SelectorHeight, args))"></button>
            </aside>
            <button type="button"
                    class="mvn-resize-handle mvn-shell-resize-handle"
                    title="Resize view selector"
                    aria-label="Resize view selector"
                    @onpointerdown="@(args => BeginPaneResize(ResizeTarget.Selector, args))"></button>
        }

        <main class="mvn-workspace">
            @if (SelectedViewItem == null || EditableObject == null)
            {
                <div class="mvn-card mvn-placeholder">
                    Select a view on the left to add or edit it.
                </div>
            }
            else
            {
                <section class="mvn-card mvn-selected-header">
                    <div class="mvn-title-block">
                        <div class="mvn-title-row">
                            <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">@SelectedViewItem.DisplayName</RadzenText>
                            <span class="mvn-status-chip">@SelectedViewClassification</span>
                        </div>
                        <RadzenText TextStyle="TextStyle.Caption" class="mvn-source-name">@CurrentSourceFullName</RadzenText>
                        <div class="mvn-title-sync-counts">
                            <span>Column Synchronization</span>
                            <span>@ColumnSummarySentence</span>
                        </div>
                    </div>

                </section>

                <div class="mvn-editor-grid">
                    <section class="mvn-card mvn-view-editor">
                        <div class="mvn-panel-header">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">View Definition</RadzenText>
                            <div class="mvn-view-tools">
                                <button type="button"
                                        class="mvn-view-tools-trigger"
                                        title="Open view-level tools"
                                        aria-expanded="@IsViewToolsOpen"
                                        @onclick="@ToggleViewTools">
                                    <RadzenIcon Icon="build" />
                                    <span>View Tools</span>
                                </button>
                                @if (IsViewToolsOpen)
                                {
                                    <div class="mvn-view-tools-menu">
                                        <button type="button"
                                                title="Review parser-detected column changes before applying synchronization decisions."
                                                disabled="@IsBusy"
                                                @onclick="@(() => RunViewToolAsync(OpenColumnMergeReviewAsync))">
                                            <RadzenIcon Icon="published_with_changes" />
                                            <span>Review Merge</span>
                                        </button>
                                        <button type="button"
                                                title="Reload this view's SQL from the database, clear parser cache for it, and rebuild the column synchronization review."
                                                disabled="@(!CanOpenDependencyTools || IsBusy)"
                                                @onclick="@(() => RunViewToolAsync(RefreshCurrentViewAsync))">
                                            <RadzenIcon Icon="sync" />
                                            <span>Refresh Parsed View</span>
                                        </button>
                                        <button type="button"
                                                title="Open the parser's view of this SQL view, including parsed columns, source chain, and the view SQL tab."
                                                disabled="@(!CanOpenDependencyTools || IsBusy)"
                                                @onclick="@(() => RunViewToolAsync(ShowParsedDependenciesAsync))">
                                            <RadzenIcon Icon="table_view" />
                                            <span>Parsed Details</span>
                                        </button>
                                        <button type="button"
                                                title="Show SQL Server dependency metadata for objects that reference this view."
                                                disabled="@(!CanOpenDependencyTools || IsBusy)"
                                                @onclick="@(() => RunViewToolAsync(ShowWhereUsedAsync))">
                                            <RadzenIcon Icon="device_hub" />
                                            <span>Where Used</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mvn-field">
                            @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.BusinessName))
                            <RadzenTextBox @bind-Value="@EditableObject.BusinessName" Style="width:100%;" MaxLength="128" />
                        </div>

                        <div class="mvn-view-definition-row">
                            <div class="mvn-field">
                                @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.Domain))
                                <RadzenDropDown Data="@Domains"
                                                TextProperty="Domain"
                                                ValueProperty="Domain"
                                                @bind-Value="@EditableObject.Domain"
                                                Style="width:100%;"
                                                AllowClear="true"
                                                Placeholder="Unknown" />
                            </div>

                            <label class="mvn-check-field">
                                @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.IsBaseObject))
                                <RadzenCheckBox Value="@EditableObject.IsBaseObject" Change="@OnBaseObjectChanged" TValue="bool" />
                            </label>
                        </div>

                        <div class="mvn-field">
                            @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.SourceTableName))
                            <RadzenTextBox @bind-Value="@EditableObject.SourceTableName"
                                           Style="width:100%;"
                                           Placeholder="Required for base objects"
                                           Disabled="@(!EditableObject.IsBaseObject)"
                                           MaxLength="128" />
                        </div>

                        <div class="mvn-field">
                            @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.BusinessDescription))
                            <RadzenTextArea @bind-Value="@EditableObject.BusinessDescription"
                                            Style="width:100%; max-width:100%; min-width:0; box-sizing:border-box; resize:vertical; overflow-y:scroll;"
                                            class="mvn-textarea"
                                            MaxLength="500" />
                        </div>

                        <div class="mvn-field">
                            @FieldLabel(typeof(SchemaObjectDefinition), nameof(SchemaObjectDefinition.DeveloperNotes))
                            <RadzenTextArea @bind-Value="@EditableObject.DeveloperNotes"
                                            Style="width:100%; max-width:100%; min-width:0; box-sizing:border-box; resize:vertical; overflow-y:scroll;"
                                            class="mvn-textarea"
                                            MaxLength="3200" />
                        </div>

                        <div class="mvn-view-actions">
                            <RadzenButton Text="Reset View Edits"
                                          Icon="restart_alt"
                                          ButtonStyle="ButtonStyle.Light"
                                          title="Discard unsaved edits for this view definition and reload its last saved values."
                                          Click="@ResetEditorAsync"
                                          Disabled="@IsBusy" />
                            <RadzenButton Text="Save All"
                                          Icon="save"
                                          title="Save the view definition and all edited column metadata together."
                                          Click="@SaveViewAsync"
                                          Disabled="@IsBusy" />
                            @if (IsSaving)
                            {
                                <span class="mvn-save-spinner" role="status" aria-live="polite">
                                    <span class="mvn-save-spinner-dot" aria-hidden="true"></span>
                                    <span>Saving</span>
                                </span>
                            }
                            @if (CanDeleteCurrentView)
                            {
                                <RadzenButton Text="Delete View"
                                              Icon="delete"
                                              ButtonStyle="ButtonStyle.Danger"
                                              title="Delete this imported Schema Studio view definition and its saved columns."
                                              Click="@DeleteViewAsync"
                                              Disabled="@IsBusy" />
                            }
                        </div>
                    </section>
                    <button type="button"
                            class="mvn-resize-handle mvn-editor-resize-handle"
                            title="Resize view definition"
                            aria-label="Resize view definition"
                            @onpointerdown="@(args => BeginPaneResize(ResizeTarget.ViewDefinition, args))"></button>

                    <section class="mvn-card mvn-column-editor">
                        <div class="mvn-panel-header">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">Column Metadata</RadzenText>
                        </div>

                        @if (CanEditColumns && SavedColumns.Count > 0)
                        {
                            <div class="mvn-column-grid">
                                <div class="mvn-column-list-panel">
                                    <div class="mvn-column-list-header">
                                        <span>Columns (@FilteredColumns.Count)</span>
                                        @MetadataHelp(nameof(SchemaObjectColumnDefinition.SourceColumnName))
                                    </div>
                                    <RadzenTextBox @bind-Value="@ColumnFilter"
                                                   Placeholder="Filter columns"
                                                   Style="width:100%;"
                                                   Change="@(_ => EnsureSelectedColumn())" />

                                    <div class="mvn-column-list">
                                        @foreach (var column in FilteredColumns)
                                        {
                                            <button type="button"
                                                    class="@GetColumnSelectorClass(column)"
                                                    title="@BuildColumnTooltip(column)"
                                                    @onclick="@(() => SelectColumn(column))">
                                                <span class="mvn-column-labels">
                                                    <strong>@column.SourceColumnName</strong>
                                                </span>
                                                @if (column.MergeState != SchemaObjectColumnMergeState.None)
                                                {
                                                    <span class="@GetColumnStateChipClass(column)">@GetColumnStateChipText(column)</span>
                                                }
                                                else if (column.IsDirty)
                                                {
                                                    <span class="mvn-edited-chip">Edited</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                                <button type="button"
                                        class="mvn-resize-handle mvn-column-list-resize-handle"
                                        title="Resize column list"
                                        aria-label="Resize column list"
                                        @onpointerdown="@(args => BeginPaneResize(ResizeTarget.ColumnList, args))"></button>

                                <div class="mvn-column-detail-panel">
                                    <div class="mvn-column-detail-header">
                                        <div>
                                            <span class="mvn-detail-label">Selected Column</span>
                                            <div class="mvn-selected-column-title">
                                                <h3>@(SelectedColumn?.SourceColumnName ?? "No column selected")</h3>
                                                @if (SelectedColumnMetadataIsInherited)
                                                {
                                                    <span class="mvn-origin-chip inherited">Inherited</span>
                                                }
                                            </div>
                                        </div>
                                        <RadzenButton Text="Reset Column Changes"
                                                      Icon="restart_alt"
                                                      Size="ButtonSize.Small"
                                                      ButtonStyle="ButtonStyle.Light"
                                                      Click="@ResetSelectedColumnAsync"
                                                      Disabled="@(SelectedColumn == null || !SelectedColumn.IsDirty || IsBusy)" />
                                    </div>

                                    @if (SelectedColumn == null)
                                    {
                                        <div class="mvn-column-empty">Select a saved column to edit its business metadata.</div>
                                    }
                                    else
                                    {
                                        <div class="mvn-column-fields">
                                            @if (!string.IsNullOrWhiteSpace(SelectedColumnInheritedFrom))
                                            {
                                                <div class="mvn-inherited-source">
                                                    <span>Inherited from</span>
                                                    <strong>@SelectedColumnInheritedFrom</strong>
                                                </div>
                                            }

                                            <label class="mvn-check-field mvn-inheritance-check">
                                                @ColumnFieldLabel(nameof(SchemaObjectColumnDefinition.DisableInheritance))
                                                <RadzenCheckBox @bind-Value="@SelectedColumn.DisableInheritance"
                                                                TValue="bool"
                                                                Disabled="@(!CanEditSelectedColumnMetadata)" />
                                            </label>

                                            <div class="mvn-field">
                                                @ColumnFieldLabel(nameof(SchemaObjectColumnDefinition.BusinessName))
                                                <RadzenTextBox @bind-Value="@SelectedColumn.BusinessName"
                                                               MaxLength="@GetMaxLength(nameof(SchemaObjectColumnDefinition.BusinessName))"
                                                               Style="width:100%;"
                                                               ReadOnly="@(!CanEditSelectedColumnMetadata)" />
                                            </div>

                                            <div class="mvn-field">
                                                @ColumnFieldLabel(nameof(SchemaObjectColumnDefinition.BusinessDescription))
                                                <RadzenTextArea @bind-Value="@SelectedColumn.BusinessDescription"
                                                                MaxLength="@GetMaxLength(nameof(SchemaObjectColumnDefinition.BusinessDescription))"
                                                                Style="width:100%; max-width:100%; min-width:0; box-sizing:border-box; resize:vertical; overflow-y:scroll;"
                                                                class="mvn-textarea"
                                                                ReadOnly="@(!CanEditSelectedColumnMetadata)" />
                                            </div>

                                            <div class="mvn-field">
                                                @ColumnFieldLabel(nameof(SchemaObjectColumnDefinition.DeveloperNotes))
                                                <RadzenTextArea @bind-Value="@SelectedColumn.DeveloperNotes"
                                                                MaxLength="@GetMaxLength(nameof(SchemaObjectColumnDefinition.DeveloperNotes))"
                                                                Style="width:100%; max-width:100%; min-width:0; box-sizing:border-box; resize:vertical; overflow-y:scroll;"
                                                                class="mvn-textarea"
                                                                ReadOnly="@(!CanEditSelectedColumnMetadata)" />
                                            </div>

                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </section>
                </div>

            }
        </main>
    </div>
</RadzenStack>

@code {
    private async Task OpenColumnMergeReviewAsync()
    {
        if (EditableObject == null || SelectedViewItem == null)
        {
            return;
        }

        if (EditableObject.SchemaObjectId <= 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Save view first", "Save the view definition before reviewing column metadata merge choices.", 3500);
            return;
        }

        if (CurrentParsedView == null)
        {
            NotificationService.Notify(NotificationSeverity.Info, "No parser result", "Refresh the parsed view before reviewing column metadata merge choices.", 3000);
            return;
        }

        var result = await DialogService.OpenAsync<ColumnReconciliationDialog>(
            $"{SelectedViewItem.DisplayName} - Column Merge Review",
            new Dictionary<string, object?>
            {
                { "ViewDisplayName", SelectedViewItem.DisplayName },
                { "IsBaseView", EditableObject.IsBaseObject },
                { "SchemaObjectId", EditableObject.SchemaObjectId },
                { "ParsedView", CurrentParsedView },
                { "ParsedColumns", CurrentParsedView.Columns },
                { "SavedColumns", SavedColumns }
            },
            new DialogOptions
            {
                Width = "90vw",
                Height = "90vh",
                Resizable = true,
                Draggable = false,
                CloseDialogOnOverlayClick = false
            });

        if (result is true)
        {
            var parsedColumns = CurrentParsedView.Columns.ToViewColumnDtos();
            ReviewRows = BuildColumnReviewRows(parsedColumns, SavedColumns, EditableObject.IsBaseObject).ToList();
            EnsureSelectedColumn();
            NotificationService.Notify(NotificationSeverity.Success, "Merge applied", "Column merge choices were staged. Use Save All Changes to commit them.", 3000);
            await InvokeAsync(StateHasChanged);
        }
    }
}
