@page "/manage-databases"
@using Microsoft.Data.SqlClient
@using SchemaStudio.AIHelpers
@using SchemaStudioWebViewer.Components.HelpSystem
@using SchemaStudioWebViewer.Utils
@inject DatabaseRepository DatabaseRepository
@inject DatabaseDomainRepository DomainRepository
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject TooltipService TooltipService
@inject AttributeService Attr

@attribute [FileVersion("2.6")]
@attribute [AIChange(
    "1.6",
    "2026-05-01 09:59 AM CDT kept Business Name on its own row and paired Business Description with Developer Notes as equal-height metadata fields.",
    AICommandStatus.Pending)]
@attribute [AIChange(
    "1.5",
    "2026-05-01 09:55 AM CDT tightened the database edit form by putting the identity fields on one logical row and compacting the action strip.",
    AICommandStatus.Pending)]
@attribute [AIChange(
    "1.4",
    "2026-05-01 09:36 AM CDT escaped the Manage Databases inline media query so Razor treats it as CSS instead of C#.",
    AICommandStatus.Pending)]
@attribute [AIChange(
    "1.3",
    "2026-05-01 09:33 AM CDT bounded Manage Databases to a Manage Views style viewport shell with a narrower database rail and locally scrolling detail panel.",
    AICommandStatus.Pending)]
@attribute [AIChange(
    "1.2",
    "2026-04-29 02:56 PM CDT added domain deletion that reassigns saved schema objects to Unknown before removing the selected domain.",
    AICommandStatus.Pending)]
@attribute [AIChange("1.1", "2026-04-23 01:03 PM CDT added the ViewNameFilter field to Manage Databases so per-database integration view filtering can be maintained in the UI.", AICommandStatus.Pending)]
@attribute [AIChange("1.0", "2026-04-22 06:31 PM CDT added help links and field-level info icons to database and domain maintenance forms.", AICommandStatus.Pending)]

<PageTitle>Manage Databases</PageTitle>

<RadzenStack Gap="0.55rem" class="manage-databases-page">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Gap="1rem"
                 class="mdb-page-header">
        <RadzenStack Gap="0.25rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.H4" class="rz-m-0">Manage Databases</RadzenText>
                <RadzenIcon Icon="help_outline"
                            Style="cursor:pointer;color:var(--rz-primary);font-size:1.25rem;"
                            @onclick="@(() => OpenHelp("manage-databases"))" />
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">
                Create and edit database records and their business domains.
            </RadzenText>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="@(isDatabaseListHidden ? "view_sidebar" : "hide_source")"
                          Text="@(isDatabaseListHidden ? "Show Database Selector" : "Hide Database Selector")"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@ToggleDatabaseList" />
            <RadzenButton Icon="add"
                          Text="New Database"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@OpenNewDatabaseDialog" />
        </RadzenStack>
    </RadzenStack>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            @loadError
        </RadzenAlert>
    }

    @if (isLoading)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    }

    <RadzenRow Gap="1rem" class="mdb-shell">
        @if (!isDatabaseListHidden)
        {
            <RadzenColumn Size="12" SizeLG="4" class="mdb-list-column">
                <div class="mdb-list-panel">
                    @if (databases.Count == 0 && !isLoading)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                            No databases exist yet. Use New Database to create the first one.
                        </RadzenAlert>
                    }
                    else
                    {
                        <RadzenDataGrid Data="@databases"
                                        TItem="DatabaseDefinition"
                                        AllowFiltering="true"
                                        AllowSorting="true"
                                        AllowPaging="true"
                                        PageSize="12"
                                        SelectionMode="DataGridSelectionMode.Single"
                                        @bind-Value="@selectedDatabases"
                                        RowSelect="@SelectDatabase"
                                        Style="height:100%;">
                            <Columns>
                                <RadzenDataGridColumn TItem="DatabaseDefinition" Property="DatabaseName" Title="Database" />
                                <RadzenDataGridColumn TItem="DatabaseDefinition" Property="BusinessName" Title="Business Name" />
                                <RadzenDataGridColumn TItem="DatabaseDefinition" Property="Active" Title="Active" Width="90px">
                                    <Template Context="database">
                                        <RadzenCheckBox Value="@database.Active" Disabled="true" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    }
                </div>
            </RadzenColumn>
        }

        <RadzenColumn Size="12" SizeLG="@(isDatabaseListHidden ? 12 : 8)" class="mdb-detail-column">
            <div class="mdb-detail-panel">
                @if (selectedDatabase is null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                        No database is selected. Create a database to begin maintaining domains.
                    </RadzenAlert>
                }
                else
                {
                    <RadzenTabs @bind-SelectedIndex="@selectedTabIndex"
                                RenderMode="TabRenderMode.Client"
                                class="mdb-detail-tabs">
                        <Tabs>
                            <RadzenTabsItem Text="Database" Icon="database">
                                <RadzenTemplateForm TItem="DatabaseDefinition"
                                                    Data="@editDatabase"
                                                    Submit="@SaveDatabase">
                                    <DataAnnotationsValidator />
                                    <RadzenStack Gap="0.25rem" class="rz-px-4 rz-pt-4">
                                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0">Edit Selected Database</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">@selectedDatabase.DatabaseName</RadzenText>
                                    </RadzenStack>
                                    @DatabaseFormFields(editDatabase)

                                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.6rem" class="mdb-form-actions">
                                        <RadzenButton Icon="refresh" Text="Reset" ButtonStyle="ButtonStyle.Light" Click="@ResetDatabaseEdit" />
                                        <RadzenButton Icon="delete"
                                                      Text="Delete"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="@DeleteDatabase" />
                                        <RadzenButton Icon="save" Text="Save Selected Database" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                                    </RadzenStack>
                                </RadzenTemplateForm>
                            </RadzenTabsItem>

                            <RadzenTabsItem Text="Domains" Icon="category">
                                <RadzenStack Gap="1rem" class="rz-p-4">
                                    <RadzenStack Orientation="Orientation.Horizontal"
                                                 AlignItems="AlignItems.Center"
                                                 JustifyContent="JustifyContent.SpaceBetween"
                                                 Gap="1rem">
                                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0">
                                            @selectedDatabase.DatabaseName Domains
                                        </RadzenText>

                                        <RadzenButton Icon="add"
                                                      Text="Add Domain"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      Click="@OpenNewDomainDialog" />
                                    </RadzenStack>

                                    @if (domains.Count == 0)
                                    {
                                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                                            This database does not have any domains yet. Use Add Domain to create the first one.
                                        </RadzenAlert>
                                    }
                                    else
                                    {
                                        <RadzenDataGrid Data="@domains"
                                                        TItem="DatabaseDomainDefinition"
                                                        AllowSorting="true"
                                                        SelectionMode="DataGridSelectionMode.Single"
                                                        @bind-Value="@selectedDomains"
                                                        RowSelect="@SelectDomain"
                                                        Style="height: 180px;">
                                            <Columns>
                                                <RadzenDataGridColumn TItem="DatabaseDomainDefinition" Property="Domain" Title="Domain" />
                                                <RadzenDataGridColumn TItem="DatabaseDomainDefinition" Property="Description" Title="Description" />
                                            </Columns>
                                        </RadzenDataGrid>
                                    }

                                    @if (selectedDomain is null)
                                    {
                                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat">
                                            Select a domain to edit it.
                                        </RadzenAlert>
                                    }
                                    else
                                    {
                                        <RadzenTemplateForm TItem="DatabaseDomainDefinition"
                                                            Data="@editDomain"
                                                            Submit="@SaveDomain">
                                            <DataAnnotationsValidator />
                                            <RadzenStack Gap="0.25rem">
                                                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0">Edit Selected Domain</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">@editDomain.Domain</RadzenText>
                                            </RadzenStack>
                                            @DomainFormFields(editDomain)

                                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.75rem">
                                                @* 2026-04-29 02:56 PM CDT AI v1.2 domain-delete marker: deleting a domain reassigns saved schema objects to Unknown instead of leaving stale domain strings. *@
                                                <RadzenButton Icon="refresh" Text="Reset" ButtonStyle="ButtonStyle.Light" Click="@ResetDomainEdit" />
                                                <RadzenButton Icon="delete"
                                                              Text="Delete Domain"
                                                              ButtonStyle="ButtonStyle.Danger"
                                                              Click="@DeleteDomain"
                                                              Disabled="@IsUnknownDomain(selectedDomain)" />
                                                <RadzenButton Icon="save" Text="Save Selected Domain" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                                            </RadzenStack>
                                        </RadzenTemplateForm>
                                    }
                                </RadzenStack>
                            </RadzenTabsItem>

                            <RadzenTabsItem Text="Relationships" Icon="account_tree">
                                <DatabaseRelationshipsPanel @key="selectedDatabase.DatabaseId"
                                                            Database="@selectedDatabase" />
                            </RadzenTabsItem>
                        </Tabs>
                    </RadzenTabs>
                }
            </div>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@if (isNewDatabaseDialogOpen)
{
    <div class="database-modal-backdrop">
        <RadzenCard class="database-modal rz-p-0">
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween"
                         class="rz-p-4 rz-border-bottom">
                <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">New Database</RadzenText>
                <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Click="@CloseNewDatabaseDialog" />
            </RadzenStack>

            <RadzenTemplateForm TItem="DatabaseDefinition"
                                Data="@newDatabase"
                                Submit="@CreateDatabase">
                <DataAnnotationsValidator />
                @DatabaseFormFields(newDatabase)

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.6rem" class="mdb-form-actions">
                    <RadzenButton Icon="close" Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@CloseNewDatabaseDialog" />
                    <RadzenButton Icon="save" Text="Create Database" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenCard>
    </div>
}

@if (isNewDomainDialogOpen && selectedDatabase is not null)
{
    <div class="database-modal-backdrop">
        <RadzenCard class="database-modal rz-p-0">
            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween"
                         class="rz-p-4 rz-border-bottom">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">Add Domain</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">@selectedDatabase.DatabaseName</RadzenText>
                </RadzenStack>
                <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Click="@CloseNewDomainDialog" />
            </RadzenStack>

            <RadzenTemplateForm TItem="DatabaseDomainDefinition"
                                Data="@newDomain"
                                Submit="@CreateDomain">
                <DataAnnotationsValidator />
                <RadzenStack Gap="1rem" class="rz-p-4">
                    @DomainFormFields(newDomain)
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.75rem" class="rz-px-4 rz-pb-4">
                    <RadzenButton Icon="close" Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@CloseNewDomainDialog" />
                    <RadzenButton Icon="save" Text="Create Domain" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenCard>
    </div>
}

