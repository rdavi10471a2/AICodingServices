@code {
    private List<DatabaseDefinition> databases = new();
    private IList<DatabaseDefinition> selectedDatabases = new List<DatabaseDefinition>();
    private List<DatabaseDomainDefinition> domains = new();
    private IList<DatabaseDomainDefinition> selectedDomains = new List<DatabaseDomainDefinition>();
    private DatabaseDefinition editDatabase = NewDatabaseDefinition();
    private DatabaseDefinition newDatabase = NewDatabaseDefinition();
    private DatabaseDefinition? selectedDatabase;
    private DatabaseDomainDefinition editDomain = new();
    private DatabaseDomainDefinition newDomain = new();
    private DatabaseDomainDefinition? selectedDomain;
    private bool isLoading;
    private bool isNewDatabaseDialogOpen;
    private bool isNewDomainDialogOpen;
    private bool isDatabaseListHidden;
    private int selectedTabIndex;
    private string loadError = "";
    private const int RelationshipsTabIndex = 2;

    protected override async Task OnInitializedAsync()
    {
        await LoadDatabasesAsync(selectFirstWhenMissing: true);
    }

    private async Task LoadDatabasesAsync(bool selectFirstWhenMissing = false)
    {
        isLoading = true;
        loadError = "";

        try
        {
            databases = (await DatabaseRepository.GetAllAsync()).ToList();

            if (selectedDatabase is not null)
            {
                selectedDatabase = databases.FirstOrDefault(x => x.DatabaseId == selectedDatabase.DatabaseId);
            }

            if (selectedDatabase is null && selectFirstWhenMissing)
            {
                selectedDatabase = databases.FirstOrDefault();
            }

            if (selectedDatabase is not null)
            {
                selectedDatabases = new List<DatabaseDefinition> { selectedDatabase };
                editDatabase = Clone(selectedDatabase);
                await LoadDomainsAsync(selectedDatabase.DatabaseId);
            }
            else
            {
                ClearDatabaseSelection();
            }
        }
        catch (Exception ex)
        {
            loadError = FriendlyError(ex);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDomainsAsync(int databaseId)
    {
        try
        {
            domains = (await DomainRepository.GetByDatabaseIdAsync(databaseId)).ToList();
            selectedDomain = domains.FirstOrDefault(x => selectedDomain is not null && x.DatabaseDomainId == selectedDomain.DatabaseDomainId);
            selectedDomain ??= domains.FirstOrDefault();

            if (selectedDomain is not null)
            {
                selectedDomains = new List<DatabaseDomainDefinition> { selectedDomain };
                editDomain = Clone(selectedDomain);
            }
            else
            {
                selectedDomains.Clear();
                editDomain = new DatabaseDomainDefinition { DatabaseId = databaseId };
            }
        }
        catch (Exception ex)
        {
            domains.Clear();
            selectedDomain = null;
            selectedDomains.Clear();
            editDomain = new DatabaseDomainDefinition { DatabaseId = databaseId };
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private async Task SelectDatabase(DatabaseDefinition database)
    {
        selectedDatabase = database;
        editDatabase = Clone(database);
        selectedDomain = null;
        await LoadDomainsAsync(database.DatabaseId);
    }

    private void ClearDatabaseSelection()
    {
        selectedDatabase = null;
        selectedDatabases.Clear();
        domains.Clear();
        selectedDomain = null;
        selectedDomains.Clear();
        editDatabase = NewDatabaseDefinition();
        editDomain = new DatabaseDomainDefinition();
        newDomain = new DatabaseDomainDefinition();
        isNewDomainDialogOpen = false;
    }

    private void OpenNewDatabaseDialog()
    {
        newDatabase = NewDatabaseDefinition();
        isNewDatabaseDialogOpen = true;
    }

    private void CloseNewDatabaseDialog()
    {
        isNewDatabaseDialogOpen = false;
    }

    private void ToggleDatabaseList()
    {
        isDatabaseListHidden = !isDatabaseListHidden;
    }

    private void ResetDatabaseEdit()
    {
        editDatabase = selectedDatabase is null
            ? NewDatabaseDefinition()
            : Clone(selectedDatabase);
    }

    private async Task CreateDatabase(DatabaseDefinition database)
    {
        try
        {
            await DatabaseRepository.CreateAsync(database);
            Notify(NotificationSeverity.Success, "Database created.");
            selectedDatabase = database;
            isNewDatabaseDialogOpen = false;
            await LoadDatabasesAsync();
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private async Task SaveDatabase(DatabaseDefinition database)
    {
        try
        {
            await DatabaseRepository.UpdateAsync(database);
            Notify(NotificationSeverity.Success, "Database updated.");
            selectedDatabase = database;
            await LoadDatabasesAsync();
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private async Task DeleteDatabase()
    {
        if (editDatabase.DatabaseId == 0)
            return;

        var confirmed = await DialogService.Confirm(
            "Delete this database? The database constraints will also delete all domains and schema objects within this database.",
            "Delete Database",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed != true)
            return;

        try
        {
            await DatabaseRepository.DeleteAsync(editDatabase.DatabaseId);
            Notify(NotificationSeverity.Success, "Database deleted.");
            selectedDatabase = null;
            await LoadDatabasesAsync(selectFirstWhenMissing: true);
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private void SelectDomain(DatabaseDomainDefinition domain)
    {
        selectedDomain = domain;
        editDomain = Clone(domain);
    }

    private void OpenNewDomainDialog()
    {
        if (selectedDatabase is null)
            return;

        newDomain = new DatabaseDomainDefinition
        {
            DatabaseId = selectedDatabase.DatabaseId
        };
        isNewDomainDialogOpen = true;
    }

    private void CloseNewDomainDialog()
    {
        isNewDomainDialogOpen = false;
    }

    private void ResetDomainEdit()
    {
        editDomain = selectedDomain is null
            ? new DatabaseDomainDefinition { DatabaseId = selectedDatabase?.DatabaseId ?? 0 }
            : Clone(selectedDomain);
    }

    private async Task SaveDomain(DatabaseDomainDefinition domain)
    {
        if (selectedDatabase is null)
            return;

        domain.DatabaseId = selectedDatabase.DatabaseId;

        if (HasDuplicateDomain(domain))
        {
            Notify(NotificationSeverity.Warning, "That domain already exists for this database. Domain names must be unique, ignoring case.");
            return;
        }

        try
        {
            if (domain.DatabaseDomainId == 0)
            {
                await DomainRepository.CreateAsync(domain);
                Notify(NotificationSeverity.Success, "Domain created.");
            }
            else
            {
                await DomainRepository.UpdateAsync(domain);
                Notify(NotificationSeverity.Success, "Domain updated.");
            }

            selectedDomain = domain;
            await LoadDomainsAsync(selectedDatabase.DatabaseId);
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private async Task CreateDomain(DatabaseDomainDefinition domain)
    {
        if (selectedDatabase is null)
            return;

        domain.DatabaseId = selectedDatabase.DatabaseId;

        if (HasDuplicateDomain(domain))
        {
            Notify(NotificationSeverity.Warning, "That domain already exists for this database. Domain names must be unique, ignoring case.");
            return;
        }

        try
        {
            await DomainRepository.CreateAsync(domain);
            Notify(NotificationSeverity.Success, "Domain created.");
            selectedDomain = domain;
            isNewDomainDialogOpen = false;
            await LoadDomainsAsync(selectedDatabase.DatabaseId);
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private async Task DeleteDomain()
    {
        if (selectedDatabase is null || selectedDomain is null)
            return;

        if (IsUnknownDomain(selectedDomain))
        {
            Notify(NotificationSeverity.Warning, "The Unknown domain cannot be deleted.");
            return;
        }

        var confirmed = await DialogService.Confirm(
            $"Delete domain \"{selectedDomain.Domain}\"? Existing saved views and schema objects assigned to this domain will be reassigned to \"{DatabaseDomainRepository.UnknownDomainName}\". Available source views are not affected until they are imported.",
            "Delete Domain",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed != true)
            return;

        try
        {
            var result = await DomainRepository.DeleteAndReassignAsync(selectedDatabase.DatabaseId, selectedDomain.Domain);

            Notify(
                NotificationSeverity.Success,
                $"Domain deleted. {result.ReassignedObjectCount} saved object(s) reassigned to {result.ReassignedDomain}.");

            selectedDomain = null;
            selectedDomains.Clear();
            editDomain = new DatabaseDomainDefinition { DatabaseId = selectedDatabase.DatabaseId };
            await LoadDomainsAsync(selectedDatabase.DatabaseId);
        }
        catch (Exception ex)
        {
            Notify(NotificationSeverity.Error, FriendlyError(ex));
        }
    }

    private RenderFragment DatabaseFormFields(DatabaseDefinition database) => @<RadzenStack Gap="0.75rem" class="mdb-form-fields">
        @* 2026-04-23 01:03 PM CDT AI v1.1 database-filter marker: Manage Databases now exposes the ViewNameFilter field for trimming integration view lists per database. *@
        @* 2026-04-22 06:31 PM CDT AI v1.0 manage-database-help marker: field labels use model Display/Description metadata for consistent help tooltips. *@
        <RadzenRow Gap="0.75rem">
            <RadzenColumn Size="12" SizeMD="6">
                @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.DatabaseName))
                <RadzenTextBox Name="DatabaseName" @bind-Value="@database.DatabaseName" Style="width:100%;" MaxLength="128" />
                <RadzenRequiredValidator Component="DatabaseName" Text="Database name is required." />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.DefaultSchema))
                <RadzenTextBox Name="DefaultSchema" @bind-Value="@database.DefaultSchema" Style="width:100%;" MaxLength="128" />
                <RadzenRequiredValidator Component="DefaultSchema" Text="Default schema is required." />
            </RadzenColumn>
        </RadzenRow>

        @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.BusinessName))
        <RadzenTextBox Name="BusinessName" @bind-Value="@database.BusinessName" Style="width:100%;" MaxLength="128" />
        <RadzenRequiredValidator Component="BusinessName" Text="Business name is required." />

        <RadzenRow Gap="0.75rem">
            <RadzenColumn Size="12" SizeMD="6">
                @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.BusinessDescription))
                <RadzenTextArea Name="BusinessDescription"
                                @bind-Value="@database.BusinessDescription"
                                Style="width:100%;"
                                class="mdb-metadata-textarea"
                                MaxLength="500" />
                <RadzenRequiredValidator Component="BusinessDescription" Text="Business description is required." />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.DeveloperNotes))
                <RadzenTextArea @bind-Value="@database.DeveloperNotes"
                                Style="width:100%;"
                                class="mdb-metadata-textarea"
                                MaxLength="4000" />
            </RadzenColumn>
        </RadzenRow>

        @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.ViewNameFilter))
        <RadzenTextBox @bind-Value="@database.ViewNameFilter" Style="width:100%;" MaxLength="256" />

        @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.SQLLookupString))
        <RadzenTextArea @bind-Value="@database.SQLLookupString"
                        Style="width:100%;"
                        Rows="5"
                        MaxLength="500" />

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenCheckBox @bind-Value="@database.Active" TValue="bool" />
            @FieldLabel(typeof(DatabaseDefinition), nameof(DatabaseDefinition.Active))
        </RadzenStack>
    </RadzenStack>;

    private RenderFragment DomainFormFields(DatabaseDomainDefinition domain) => @<RadzenStack Gap="1rem">
        @FieldLabel(typeof(DatabaseDomainDefinition), nameof(DatabaseDomainDefinition.Domain))
        <RadzenTextBox Name="Domain" @bind-Value="@domain.Domain" Style="width:100%;" MaxLength="128" />
        <RadzenRequiredValidator Component="Domain" Text="Domain is required." />

        @FieldLabel(typeof(DatabaseDomainDefinition), nameof(DatabaseDomainDefinition.Description))
        <RadzenTextArea @bind-Value="@domain.Description" Style="width:100%;" Rows="4" MaxLength="500" />
    </RadzenStack>;

    private RenderFragment FieldLabel(Type modelType, string propertyName) => @<div class="manage-field-label">
        @Attr.GetName($"{modelType.Name}.{propertyName}")
        @{
            var description = Attr.GetDesc($"{modelType.Name}.{propertyName}");
        }
        @if (!string.IsNullOrWhiteSpace(description))
        {
            <RadzenIcon Icon="help_outline"
                        MouseEnter="@(args => TooltipService.Open(args, description))" />
        }
    </div>;

    private async Task OpenHelp(string id)
    {
        await DialogService.OpenAsync<HelpDialog>(
            "Schema Studio Help Console",
            new Dictionary<string, object?>
            {
                { "InitialSubjectId", id }
            },
            new DialogOptions
            {
                Width = "1200px",
                Height = "800px",
                Resizable = true,
                Draggable = true
            });
    }

    private static DatabaseDefinition NewDatabaseDefinition() =>
        new()
        {
            DefaultSchema = "dbo",
            Active = true
        };

    private static DatabaseDefinition Clone(DatabaseDefinition database) =>
        new()
        {
            DatabaseId = database.DatabaseId,
            DatabaseName = database.DatabaseName,
            DefaultSchema = database.DefaultSchema,
            BusinessName = database.BusinessName,
            BusinessDescription = database.BusinessDescription,
            DeveloperNotes = database.DeveloperNotes,
            ViewNameFilter = database.ViewNameFilter,
            SQLLookupString = database.SQLLookupString,
            Active = database.Active
        };

    private static DatabaseDomainDefinition Clone(DatabaseDomainDefinition domain) =>
        new()
        {
            DatabaseDomainId = domain.DatabaseDomainId,
            DatabaseId = domain.DatabaseId,
            Domain = domain.Domain,
            Description = domain.Description
        };

    private bool HasDuplicateDomain(DatabaseDomainDefinition domain)
    {
        var candidate = domain.Domain.Trim();

        return domains.Any(existing =>
            existing.DatabaseDomainId != domain.DatabaseDomainId &&
            string.Equals(existing.Domain.Trim(), candidate, StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsUnknownDomain(DatabaseDomainDefinition? domain) =>
        domain is not null &&
        string.Equals(domain.Domain.Trim(), DatabaseDomainRepository.UnknownDomainName, StringComparison.OrdinalIgnoreCase);

    private void Notify(NotificationSeverity severity, string detail)
    {
        NotificationService.Notify(new NotificationMessage
        {
            Severity = severity,
            Summary = severity == NotificationSeverity.Error ? "Save failed" : "Manage Databases",
            Detail = detail,
            Duration = 3500
        });
    }

    private static string FriendlyError(Exception ex)
    {
        if (ex is SqlException sqlException && sqlException.Number is 2601 or 2627)
        {
            return "A database domain with that name already exists for this database.";
        }

        return ex.Message;
    }
}
