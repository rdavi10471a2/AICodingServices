        MarkSqlDirty();

        if (Columns.Count > 0)
        {
            StatusMessage = BuildLoadedStatusMessage();
        }
    }

    private async Task LoadSavedLookupRelationshipsAsync(DatabaseDefinition? selectedDatabase)
    {
        ClearLookupRelationshipState();

        if (selectedDatabase is null || selectedDatabase.DatabaseId == 0)
        {
            return;
        }

        SavedLookupRelationships = (await LookupRelationshipRepository.GetBySourceAsync(
            selectedDatabase.DatabaseId,
            SelectedSchemaName,
            SelectedTableName)).ToList();
        SavedLookupRelationshipKeys = SavedLookupRelationships
            .Select(BuildRelationshipRegistryKey)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void ApplySavedLookupRelationships()
    {
        foreach (var savedRelationship in SavedLookupRelationships.Where(relationship => relationship.Active))
        {
            var key = BuildRelationshipRegistryKey(savedRelationship);
            var existing = AllRelationships.FirstOrDefault(relationship => string.Equals(BuildRelationshipRegistryKey(relationship), key, StringComparison.OrdinalIgnoreCase));

            if (existing is not null)
            {
                existing.DisplayColumnName = savedRelationship.LookupDisplayColumnName;
                existing.SelectedJoinType = savedRelationship.JoinType;
                existing.Include = true;
                existing.IncludeDisplayColumn = !string.IsNullOrWhiteSpace(savedRelationship.LookupDisplayColumnName);
                continue;
            }

            AllRelationships.Add(new TableSchemaRelationshipInfo(
                string.IsNullOrWhiteSpace(savedRelationship.RelationshipName)
                    ? $"REGISTERED_{savedRelationship.SourceTableName}_{savedRelationship.SourceColumnName}_{savedRelationship.LookupTableName}"
                    : savedRelationship.RelationshipName,
                savedRelationship.LookupSchemaName,
                savedRelationship.LookupTableName,
                savedRelationship.LookupDisplayColumnName,
                string.Equals(savedRelationship.JoinType, "INNER JOIN", StringComparison.OrdinalIgnoreCase),
                savedRelationship.JoinType,
                [new TableSchemaForeignKeyColumnInfo(savedRelationship.SourceColumnName, savedRelationship.LookupKeyColumnName)],
                savedRelationship.LookupFilterColumnName,
                savedRelationship.LookupFilterValue));
        }
    }

    private void ClearLookupRelationshipState()
