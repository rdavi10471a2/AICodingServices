@attribute [AIChange("3.2", "2026-04-24 03:03 PM CDT wired Review Merge to the first-pass added-columns dialog so a newly saved parent view can initialize accepted child SchemaObjectColumn rows through SaveAllAsync.", AICommandStatus.Pending)]
@attribute [AIChange("3.1", "2026-04-24 11:14 AM CDT tightened the manage-views tab layout after the folder move by restoring full-height selector tabs and adding dedicated classes so the selector and editor tab surfaces can be styled independently.", AICommandStatus.Pending)]
@attribute [AIChange("3.0", "2026-04-24 11:06 AM CDT moved the Manage Views page and its child components into a single ManageViews feature folder so the layout, fragment references, and isolated styles live together without the old sibling-folder split.", AICommandStatus.Pending)]
@attribute [AIChange("2.9", "2026-04-24 10:46 AM CDT extracted the saved-columns tab into a child fragment, moved page styling into isolated css, and corrected the fragment namespace path to ManageViewsFragments so the page shell is easier to navigate without colliding with the ManageViews component type.", AICommandStatus.Pending)]
@attribute [AIChange("2.8", "2026-04-24 10:20 AM CDT added parser-style help indicators to the saved-columns grid headers so the maintenance grid exposes the same tooltip cues as the parser grids.", AICommandStatus.Pending)]
@attribute [AIChange("2.7", "2026-04-24 09:49 AM CDT restored the saved-columns grid to the six requested business columns and added a hide-show toggle for the left selector panel so the main workspace can reclaim horizontal space.", AICommandStatus.Pending)]
@attribute [AIChange("2.6", "2026-04-24 09:39 AM CDT tightened the saved-columns tab with standard column metadata, 100px scrolling text cells, sticky headers, wrapped header labels, and darker inheritance checkboxes so the grid reads like a real maintenance surface.", AICommandStatus.Pending)]
@attribute [AIChange("2.5", "2026-04-24 09:20 AM CDT moved the column synchronization summary into its own reusable component and turned the Columns tab into the actual saved-column maintenance surface with a placeholder edit hook.", AICommandStatus.Pending)]
@attribute [AIChange("2.4", "2026-04-23 04:34 PM CDT kept developer notes editable on the view definition while leaving them out of the column-review merge path and parser-driven comparison rules.", AICommandStatus.Pending)]
@attribute [AIChange("2.3", "2026-04-23 04:07 PM CDT removed parser ownership of developer notes from the column merge review so parsed comments no longer show up as imported developer-note changes.", AICommandStatus.Pending)]
@attribute [AIChange("2.2", "2026-04-23 04:01 PM CDT replaced the dirty-state yellow banner with discard-confirm popups, stopped defaulting business name for available drafts, and flattened the joined left-side selector layout again.", AICommandStatus.Pending)]
@attribute [AIChange("2.1", "2026-04-23 03:49 PM CDT fixed the new-available draft workflow so brand new view definitions start clean instead of dirty, and hid delete for items that do not yet exist in Schema Studio.", AICommandStatus.Pending)]
@attribute [AIChange("2.0", "2026-04-23 03:41 PM CDT reorganized the RHS into View Definition and Manage Columns tabs, added dependency-tool actions beneath the header editor, and blocked navigation away from dirty header edits until they are saved or reset.", AICommandStatus.Pending)]
@attribute [AIChange("1.9", "2026-04-23 03:27 PM CDT collapsed the left rail into a single container, removed the extra filter summary text, and trimmed the available-view display names by the configured prefix so SQL-style naming tax stays out of the selector.", AICommandStatus.Pending)]
@attribute [AIChange("1.8", "2026-04-23 03:18 PM CDT removed the extra summary text, combined existing and available views into a shared tabbed selector, and made database/domain filter changes clear the current selection state instead of silently keeping stale view details.", AICommandStatus.Pending)]
@attribute [AIChange("1.7", "2026-04-23 02:52 PM CDT removed extra summary weight from the manage-views header and rearranged metadata into a name-domain-base row above side-by-side description and notes editors.", AICommandStatus.Pending)]
@attribute [AIChange("1.6", "2026-04-23 02:46 PM CDT moved the left-side domain filter under the database picker and aligned business name and description into equal-height side-by-side fields.", AICommandStatus.Pending)]
