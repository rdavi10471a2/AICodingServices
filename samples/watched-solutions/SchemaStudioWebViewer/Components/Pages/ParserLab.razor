@page "/parser-lab"

@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using SchemaStudio.AIHelpers
@using SchemaStudioWebViewer.Models
@using SchemaStudioWebViewer.Components.Dialogs
@using SchemaStudioWebViewer.Utils
@using SchemaStudio.Data.Models
@using SchemaStudio.Data.Repositories
@using SchemaStudioWebViewer.WEBSemanticModel.Model
@using SchemaStudioWebViewer.WEBSemanticModel.Services
@using Radzen
@using Radzen.Blazor

@inject DialogService DialogService
@inject NotificationService NotificationService
@inject TooltipService TooltipService
@inject ViewParsingService ParserService
@inject DatabaseRepository DatabaseRepository
@inject DatabaseDomainRepository DatabaseDomainRepository
@inject SchemaObjectRepository SchemaObjectRepository
@inject SqlObjectDependencyRepository SqlObjectDependencyRepository

@attribute [FileVersion("1.3")]
@attribute [AIChange("1.3", "2026-04-28 10:26 PM CDT restored ParserLab grid sizing to Radzen's normal layout after the wide inspection layout made the workspace unusable.", AICommandStatus.Pending)]
@attribute [AIChange("1.2", "2026-04-28 10:18 PM CDT improved ParserLab grid scrolling and column sizing so physical and semantic lineage fields have enough room to be inspected.", AICommandStatus.Pending)]
@attribute [AIChange("1.1", "2026-04-28 09:50 PM CDT added parser grid sizing for the reflected semantic source column so semantic lookup targets surface cleanly in ParserLab.", AICommandStatus.Pending)]
@attribute [AIChange("1.0", "2026-04-23 10:00 AM CDT added a visible parser load-error alert and removed the unused async state from the parser refresh path.", AICommandStatus.Pending)]
@attribute [AIFileContext("Components/Pages/ParserLab.razor", "Hosts the parser playground for browsing schema objects, running parser previews, and inspecting parser-derived dependencies and where-used details.")]

<style>
    .parser-page-shell {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 1rem;
        box-shadow: none !important;
    }

    .parser-panel {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 1rem;
        height: 100%;
        box-sizing: border-box;
        box-shadow: none !important;
    }

    .parser-grid-frame {
        border: 1px solid #dee2e6;
        border-radius: 4px;
        overflow: hidden;
        height: 100%;
        flex: 1 1 auto;
        min-height: 0;
    }

    .parser-picker-frame {
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 0.5rem;
        background: #fafbfc;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1 1 auto;
        min-height: 0;
    }

    .parser-workspace {
        height: min(780px, calc(100vh - 170px));
        display: grid;
        grid-template-columns: 240px minmax(0, 1fr);
        gap: 0.75rem;
    }

    .parser-left-pane {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        height: 100%;
        min-height: 0;
    }

    .parser-right-pane {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }

    .parser-tab-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 100%;
    }

    .parser-tabs {
        height: calc(100% - 52px);
        min-height: 0;
    }

    .parser-tab-content {
        height: calc(100% - 48px);
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .parser-data-host {
        flex: 0 0 95%;
        height: 95%;
        min-height: 0;
    }

    .parser-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        border: 1px dashed #cbd3da;
        border-radius: 4px;
        background: #fafbfc;
        color: #6c757d;
        font-size: 0.95rem;
        text-align: center;
        padding: 1.5rem;
    }

    .parser-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
    }

    .parser-toolbar-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .parser-data-grid {
        flex: 1 1 auto;
        height: 100% !important;
        min-height: 100% !important;
        width: 100% !important;
    }

    .parser-tabs .rz-tabview,
    .parser-tabs .rz-tabview-panels,
    .parser-tabs .rz-tabview-panel {
        height: 100%;
        min-height: 0;
    }

    .parser-tabs .rz-tabview-panels {
        padding: 0;
        border: none;
        background: transparent;
        box-shadow: none !important;
    }

    .parser-tabs .rz-tabview-panel {
        display: flex;
        flex-direction: column;
    }

    .parser-tabs .rz-tabview-nav li a {
        box-shadow: none !important;
    }

    .parser-left-pane .rz-listbox {
        overflow-y: auto;
    }

    .parser-listbox {
        width: 100%;
        min-height: 0;
    }

    .parser-listbox-base {
        height: 180px;
    }

    .parser-listbox-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .parser-listbox-derived-wrap {
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
        min-height: 0;
    }

    .parser-listbox-derived {
        flex: 1 1 auto;
    }

    .parser-section-title {
        color: var(--rz-primary);
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .view-label-blue {
        color: var(--rz-primary) !important;
        font-weight: 400 !important;
        text-transform: uppercase !important;
        font-size: 0.75rem !important;
        display: flex;
        align-items: center;
        gap: 4px;
        min-height: 24px;
    }

</style>

<PageTitle>Parser Test Area</PageTitle>

@* 2026-04-23 10:00 AM CDT AI v1.0 parser-inline-error marker: ParserLab now keeps a visible load-error alert and the parser refresh path no longer advertises async work it never awaited. *@
@* 2026-04-28 10:26 PM CDT AI v1.3 parser grid marker: restored Radzen's normal grid width handling after the wide overflow layout made the page unusable. *@
@* 2026-04-28 10:18 PM CDT AI v1.2 parser grid marker: parser grids now use horizontal overflow and wider lineage/metadata columns for inspection-heavy parsing sessions. *@
@* 2026-04-28 09:50 PM CDT AI v1.1 parser semantic-source marker: reflected parser columns reserve width for the new Semantic Source display field. *@
@* 2026-04-15 04:19 PM CDT AI parser lab marker: make the tab workspace full height and remove shadow-heavy card styling from the parser page. *@

<RadzenStack Gap="1rem">
    <RadzenCard Variant="Variant.Flat" Class="parser-page-shell">
        <RadzenText TextStyle="TextStyle.H5" Class="rz-m-0">Parser Test Area</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">
            Select a source view on the left to parse it and inspect parser-derived source tables and projected columns on the right.
        </RadzenText>
    </RadzenCard>

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
            @LoadError
        </RadzenAlert>
    }

    <div class="parser-workspace">
        <div class="parser-panel parser-left-pane">
            <div class="parser-section-title">Select View</div>

            <RadzenStack Gap="0.75rem">
                <RadzenDropDown Data="@Databases"
                                TextProperty="DatabaseName"
                                ValueProperty="DatabaseId"
                                Placeholder="Database"
                                @bind-Value="@SelectedDatabaseId"
                                Change="@OnDatabaseChanged"
                                Style="width:100%;"
                                AllowClear="true" />

                <RadzenDropDown Data="@Domains"
                                TextProperty="Domain"
                                ValueProperty="Domain"
                                Placeholder="Business Domain"
                                @bind-Value="@SelectedDomain"
                                Change="@OnDomainChanged"
                                Disabled="@(!SelectedDatabaseId.HasValue)"
                                Style="width:100%;"
                                AllowClear="true" />
            </RadzenStack>

            <div class="parser-picker-frame">
                <div class="parser-listbox-group">
                    <div class="parser-section-title" style="font-size:0.85rem;margin-bottom:0;">Base Objects</div>
                    <RadzenListBox Data="@BaseDisplayObjects"
                                   TextProperty="DisplayName"
                                   ValueProperty="SchemaObjectId"
                                   TValue="int?"
                                   @bind-Value="@SelectedObjectId"
                                   Change="@OnObjectChanged"
                                   Disabled="@string.IsNullOrWhiteSpace(SelectedDomain)"
                                   Class="parser-listbox parser-listbox-base" />
                </div>

                <div class="parser-listbox-derived-wrap">
                    <div class="parser-section-title" style="font-size:0.85rem;margin-bottom:0.5rem;">Derived Views</div>
                    <RadzenListBox Data="@DerivedDisplayObjects"
                                   TextProperty="DisplayName"
                                   ValueProperty="SchemaObjectId"
                                   TValue="int?"
                                   @bind-Value="@SelectedObjectId"
                                   Change="@OnObjectChanged"
                                   Disabled="@string.IsNullOrWhiteSpace(SelectedDomain)"
                                   Class="parser-listbox parser-listbox-derived" />
                </div>
            </div>
        </div>

        <div class="parser-right-pane">
            <div class="parser-toolbar">
                <div>
                    @if (SelectedObject != null)
                    {
                        <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;">
                            @SelectedObject.BusinessName
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">
                            @SelectedObject.SourceDatabaseName.@SelectedObject.SourceSchemaName.@SelectedObject.SourceObjectName
                            | Tables: @ParsedTables.Count | Columns: @ParsedColumns.Count
                        </RadzenText>
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color:#495057;">
                            Selection parses automatically. Use the toolbar for SQL, reload, and cache control.
                        </RadzenText>
                    }
                </div>

                <div class="parser-toolbar-actions">
                    <RadzenButton Text="Show SQL"
                                  Icon="code"
                                  Disabled="@(SelectedObject == null || IsLoading)"
                                  Click="@ShowParserSqlAsync" />

                    <RadzenButton Text="Reload"
                                  Icon="refresh"
                                  Disabled="@(SelectedObject == null || IsLoading)"
                                  Click="@ReloadSelectedViewAsync" />

                    <RadzenButton Text="Dependencies"
                                  Icon="account_tree"
                                  Disabled="@(CurrentParsedView == null || IsLoading)"
                                  Click="@ShowParsedDependenciesAsync" />

                    <RadzenButton Text="Where Used"
                                  Icon="travel_explore"
                                  Disabled="@(SelectedObject == null || IsLoading)"
                                  Click="@ShowWhereUsedAsync" />

                    <RadzenButton Text="Clear Cache"
                                  Icon="delete_sweep"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Disabled="@IsLoading"
                                  Click="@ClearParserCacheAsync" />
                </div>
            </div>

            <div class="parser-tabs">
                <RadzenTabs Style="height:100%;">
                    <Tabs>
                        <RadzenTabsItem Text="Tables">
                            <div class="parser-tab-content">
                                <div class="parser-panel parser-tab-panel parser-data-host">
                                    <div class="parser-section-title">Parsed Source Tables</div>
                                    <div class="parser-grid-frame">
                                        <RadzenDataGrid Data="@ParsedTables"
                                                                    TItem="SourceTableDto"
                                                                    Class="parser-data-grid"
                                                                    AllowPaging="false"
                                                                    AllowFiltering="true"
                                                                    AllowColumnResize="true"
                                                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                                    Density="Density.Compact"
                                                                    Style="min-width:1600px;"
                                                                    RowDoubleClick="@(args => OpenDtoDetails(args.Data, args.Data.PhysicalSourceName, "Table"))">
                                                        <Columns>
                                                            @foreach (var prop in TableProperties)
                                                            {
                                                                <RadzenDataGridColumn TItem="SourceTableDto"
                                                                                      Property="@prop.Name"
                                                                                      Width="@GetColumnWidth(prop.Name, false)">
                                                                    <HeaderTemplate>
                                                                        <div class="view-label-blue">
                                                                            @ReflectionUtils.GetDisplayName(typeof(SourceTableDto), prop.Name)
                                                                            @{
                                                                                var description = ReflectionUtils.GetDescription(typeof(SourceTableDto), prop.Name);
                                                                            }
                                                                            @if (!string.IsNullOrWhiteSpace(description))
                                                                            {
                                                                                <RadzenIcon Icon="help_outline"
                                                                                            MouseEnter="@(args => TooltipService.Open(args, description))" />
                                                                            }
                                                                        </div>
                                                                    </HeaderTemplate>
                                                                </RadzenDataGridColumn>
                                                            }
                                                        </Columns>
                                        </RadzenDataGrid>
                                    </div>
                                </div>
                            </div>
                        </RadzenTabsItem>

                        <RadzenTabsItem Text="Columns">
                            <div class="parser-tab-content">
                                <div class="parser-panel parser-tab-panel parser-data-host">
                                    <div class="parser-section-title">Parsed View Columns</div>
                                    <div class="parser-grid-frame">
                                        <RadzenDataGrid Data="@ParsedColumns"
                                                                    TItem="ViewColumnDto"
                                                                    Class="parser-data-grid"
                                                                    AllowPaging="false"
                                                                    AllowFiltering="true"
                                                                    AllowColumnResize="true"
                                                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                                    Density="Density.Compact"
                                                                    Style="min-width:2100px;"
                                                                    RowDoubleClick="@(args => OpenDtoDetails(args.Data, args.Data.ColumnName, "Column"))">
                                                        <Columns>
                                                            @foreach (var prop in ColumnProperties)
                                                            {
                                                                <RadzenDataGridColumn TItem="ViewColumnDto"
                                                                                      Property="@prop.Name"
                                                                                      Width="@GetColumnWidth(prop.Name, true)">
                                                                    <HeaderTemplate>
                                                                        <div class="view-label-blue">
                                                                            @ReflectionUtils.GetDisplayName(typeof(ViewColumnDto), prop.Name)
                                                                            @{
                                                                                var description = ReflectionUtils.GetDescription(typeof(ViewColumnDto), prop.Name);
                                                                            }
                                                                            @if (!string.IsNullOrWhiteSpace(description))
                                                                            {
                                                                                <RadzenIcon Icon="help_outline"
                                                                                            MouseEnter="@(args => TooltipService.Open(args, description))" />
                                                                            }
                                                                        </div>
                                                                    </HeaderTemplate>
                                                                </RadzenDataGridColumn>
                                                            }
                                                        </Columns>
                                        </RadzenDataGrid>
                                    </div>
                                </div>
                            </div>
                        </RadzenTabsItem>

                        <RadzenTabsItem Text="AI Markdown">
                            <div class="parser-tab-content">
                                <div class="parser-panel parser-tab-panel">
                                    <div class="parser-section-title">AI Markdown</div>
                                    <div class="parser-placeholder">
                                        AI Markdown preview will land here once we wire the generated parser notes into this workspace.
                                    </div>
                                </div>
                            </div>
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            </div>
        </div>
    </div>
</RadzenStack>

@code {
    private List<DatabaseDefinition> Databases = new();
    private List<DatabaseDomainDefinition> Domains = new();
    private List<DisplaySchemaObject> DisplayObjects = new();
    private List<SourceTableDto> ParsedTables = new();
    private List<ViewColumnDto> ParsedColumns = new();
    private ParsedQuery? CurrentParsedView;

    private int? SelectedDatabaseId;
    private string SelectedDomain = string.Empty;
    private int? SelectedObjectId;
    private SchemaObjectDefinition? SelectedObject;
    private bool IsLoading;
    private int _parseRequestVersion;
    private string LoadError = string.Empty;

    private List<PropertyInfo> TableProperties => GetVisibleGridProperties(typeof(SourceTableDto)).ToList();
    private List<PropertyInfo> ColumnProperties => GetVisibleGridProperties(typeof(ViewColumnDto)).ToList();
    private List<DisplaySchemaObject> BaseDisplayObjects => DisplayObjects.Where(x => !x.IsHeader && x.IsBaseObject).ToList();
    private List<DisplaySchemaObject> DerivedDisplayObjects => DisplayObjects.Where(x => !x.IsHeader && !x.IsBaseObject).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Databases = (await DatabaseRepository.GetAllAsync()).ToList();
            LoadError = string.Empty;
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Database load failed", ex);
        }
    }

    private async Task OnDatabaseChanged(object value)
    {
        _parseRequestVersion++;

        if (!int.TryParse(value?.ToString(), out var dbId))
        {
            ResetSelection(clearDatabase: true);
            return;
        }

        SelectedDatabaseId = dbId;
        SelectedDomain = string.Empty;
        SelectedObjectId = null;
        SelectedObject = null;
        ParsedTables = new();
        ParsedColumns = new();
        CurrentParsedView = null;
        DisplayObjects.Clear();
        await InvokeAsync(StateHasChanged);
        try
        {
            Domains = (await DatabaseDomainRepository.GetByDatabaseIdAsync(dbId)).ToList();
            LoadError = string.Empty;
        }
        catch (Exception ex)
        {
            Domains = new();
            NotifyLoadFailure("Domain load failed", ex);
        }
    }

    private async Task OnDomainChanged(object value)
    {
        _parseRequestVersion++;
        SelectedDomain = value?.ToString() ?? string.Empty;
        SelectedObjectId = null;
        SelectedObject = null;
        ParsedTables = new();
        ParsedColumns = new();
        CurrentParsedView = null;
        DisplayObjects.Clear();
        await InvokeAsync(StateHasChanged);

        if (!SelectedDatabaseId.HasValue || string.IsNullOrWhiteSpace(SelectedDomain))
        {
            return;
        }

        try
        {
            var raw = await SchemaObjectRepository.GetByDatabaseAsync(SelectedDatabaseId.Value);
            BuildDisplayObjects(raw);
            LoadError = string.Empty;
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Object load failed", ex);
        }
    }

    private async Task OnObjectChanged(object value)
    {
        _parseRequestVersion++;

        if (!int.TryParse(value?.ToString(), out var objId) || objId <= 0)
        {
            SelectedObjectId = null;
            SelectedObject = null;
            ParsedTables = new();
            ParsedColumns = new();
            CurrentParsedView = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SelectedObjectId = objId;
        try
        {
            SelectedObject = await SchemaObjectRepository.GetByIdAsync(objId);
            LoadError = string.Empty;
        }
        catch (Exception ex)
        {
            SelectedObject = null;
            NotifyLoadFailure("Object load failed", ex);
            return;
        }

        if (SelectedObject == null)
        {
            NotificationService.Notify(
                NotificationSeverity.Warning,
                "Object unavailable",
                "The selected object was not found in the metadata repository.",
                3000);
            return;
        }

        ParsedTables = new();
        ParsedColumns = new();
        CurrentParsedView = null;
        await InvokeAsync(StateHasChanged);
        await ParseSelectedViewInternalAsync(reloadSelectedView: false);
    }

    private async Task ReloadSelectedViewAsync()
    {
        await ParseSelectedViewInternalAsync(reloadSelectedView: true);
    }

    private async Task ShowParserSqlAsync()
    {
        if (SelectedObject == null)
        {
            return;
        }

        try
        {
            var sqlContent = ParserService.GetViewSql(
                SelectedObject.SourceDatabaseName ?? string.Empty,
                SelectedObject.SourceSchemaName,
                SelectedObject.SourceObjectName) ?? string.Empty;

            if (string.IsNullOrWhiteSpace(sqlContent))
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Parser SQL unavailable",
                    "The parser service did not return SQL for the selected view.");
                return;
            }

            await DialogService.OpenAsync<ViewSQLDialog>(
                $"Parser SQL: {SelectedObject.SourceObjectName}",
                new Dictionary<string, object>
                {
                    { "SqlContent", sqlContent },
                    { "IsMock", false }
                },
                new DialogOptions
                {
                    Width = "1200px",
                    Height = "820px",
                    Resizable = true,
                    Draggable = true
                });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Parser SQL failed",
                ex.Message,
                5000);
        }
    }

    private Task ParseSelectedViewInternalAsync(bool reloadSelectedView)
    {
        if (SelectedObject == null)
        {
            return Task.CompletedTask;
        }

        var requestVersion = _parseRequestVersion;
        var selectedObjectId = SelectedObject.SchemaObjectId;
        var sourceDatabaseName = SelectedObject.SourceDatabaseName ?? string.Empty;
        var sourceSchemaName = SelectedObject.SourceSchemaName;
        var sourceObjectName = SelectedObject.SourceObjectName;

        IsLoading = true;

        try
        {
            var parsed = reloadSelectedView
                ? ParserService.ReloadView(
                    sourceDatabaseName,
                    sourceSchemaName,
                    sourceObjectName)
                : ParserService.ParseView(
                    sourceDatabaseName,
                    sourceSchemaName,
                    sourceObjectName);

            if (requestVersion != _parseRequestVersion ||
                SelectedObject == null ||
                SelectedObject.SchemaObjectId != selectedObjectId)
            {
                return Task.CompletedTask;
            }

            ParsedTables = parsed?.SourceTables.ToSourceTableDtos() ?? new List<SourceTableDto>();
            ParsedColumns = parsed?.Columns.ToViewColumnDtos() ?? new List<ViewColumnDto>();
            CurrentParsedView = parsed;
            LoadError = string.Empty;

            if (ParsedTables.Count == 0 && ParsedColumns.Count == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Parser returned no data",
                    "The parser completed, but it did not return any tables or columns for the selected view.");
            }
        }
        catch (Exception ex)
        {
            if (requestVersion == _parseRequestVersion)
            {
                ParsedTables = new();
                ParsedColumns = new();
                CurrentParsedView = null;
            }
            NotifyLoadFailure("Parser failed", ex);
        }
        finally
        {
            IsLoading = false;
        }

        return Task.CompletedTask;
    }

    private Task ClearParserCacheAsync()
    {
        ParserService.ClearCache();

        NotificationService.Notify(
            NotificationSeverity.Info,
            "Parser cache cleared",
            "The parser SQL cache has been cleared for this page session.",
            3000);

        return Task.CompletedTask;
    }

    private async Task ShowParsedDependenciesAsync()
    {
        var dependencies = CurrentParsedView.GetResolvedDependencies();

        if (dependencies.Count == 0)
        {
            NotificationService.Notify(
                NotificationSeverity.Info,
                "No dependencies",
                "The current parser result does not contain named object dependencies.",
                3000);
            return;
        }

        await DialogService.OpenAsync<ParsedDependenciesDialog>(
            $"Parsed Dependencies: {SelectedObject?.SourceObjectName}",
            new Dictionary<string, object>
            {
                { "Dependencies", dependencies }
            },
            new DialogOptions
            {
                Width = "1100px",
                Height = "760px",
                Resizable = true,
                Draggable = true
            });
    }

    private async Task ShowWhereUsedAsync()
    {
        if (SelectedObject == null)
        {
            return;
        }

        try
        {
            // 2026-04-22 06:20 PM CDT AI where-used marker: use SQL Server dependency metadata for the reverse "who uses this object" side.
            var dependencies = await SqlObjectDependencyRepository.GetWhereUsedAsync(
                SelectedObject.SourceDatabaseName ?? string.Empty,
                SelectedObject.SourceSchemaName,
                SelectedObject.SourceObjectName);
            LoadError = string.Empty;

            if (dependencies.Count == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Info,
                    "No where-used rows",
                    "SQL Server dependency metadata does not list any objects using the selected object.",
                    3000);
                return;
            }

            await DialogService.OpenAsync<SqlObjectDependenciesDialog>(
                $"Where Used: {SelectedObject.SourceObjectName}",
                new Dictionary<string, object?>
                {
                    { "Dependencies", dependencies }
                },
                new DialogOptions
                {
                    Width = "1100px",
                    Height = "620px",
                    Resizable = true,
                    Draggable = true
                });
        }
        catch (Exception ex)
        {
            NotifyLoadFailure("Where-used lookup failed", ex);
        }
    }

    private async Task OpenDtoDetails(object model, string? label, string kind)
    {
        await DialogService.OpenAsync<DynamicDetailForm>(
            $"{kind} Details: {label}",
            new Dictionary<string, object>
            {
                { "Model", model }
            },
            new DialogOptions
            {
                Width = "900px",
                Height = "800px",
                Resizable = true,
                Draggable = true
            });
    }

    private static IEnumerable<PropertyInfo> GetVisibleGridProperties(Type type)
    {
        return type.GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Select(prop => new
            {
                Property = prop,
                Display = prop.GetCustomAttribute<DisplayAttribute>(),
                DetailOnly = prop.GetCustomAttribute<DetailViewOnlyAttribute>()
            })
            .Where(x =>
                x.Display != null &&
                x.Display.GetAutoGenerateField() != false &&
                (x.DetailOnly == null || x.DetailOnly.IsDetailOnly == false))
            .OrderBy(x => x.Display?.GetOrder() ?? 99)
            .Select(x => x.Property);
    }

    private static string GetColumnWidth(string propertyName, bool isColumnGrid)
    {
        return propertyName switch
        {
            nameof(ViewColumnDto.OrdinalPosition) => "72px",
            nameof(SourceTableDto.ResolvedOrder) => "130px",
            nameof(SourceTableDto.Kind) => "130px",
            nameof(SourceTableDto.Database) => "150px",
            nameof(SourceTableDto.Schema) => "120px",
            nameof(SourceTableDto.Table) => "190px",
            nameof(SourceTableDto.Alias) => "130px",
            nameof(SourceTableDto.ParentAlias) => "150px",
            nameof(SourceTableDto.JoinType) => "130px",
            nameof(SourceTableDto.JoinExpression) => "260px",
            nameof(SourceTableDto.IsBaseTable) => "120px",
            nameof(SourceTableDto.PhysicalSourceName) => "260px",
            nameof(ViewColumnDto.FullyQualifiedSourceColumnName) => "320px",
            nameof(ViewColumnDto.FullyQualifiedSemanticColumnName) => "360px",
            nameof(ViewColumnDto.ColumnName) => "180px",
            nameof(ViewColumnDto.ColumnKind) => "150px",
            nameof(ViewColumnDto.BusinessName) => "180px",
            nameof(ViewColumnDto.BusinessDescription) => "240px",
            nameof(ViewColumnDto.DeveloperNotes) => "220px",
            nameof(ViewColumnDto.Comment) => "240px",
            _ => isColumnGrid ? "170px" : "150px"
        };
    }

    private void BuildDisplayObjects(IReadOnlyList<SchemaObjectDefinition> raw)
    {
        var filtered = raw.Where(x => x.Domain == SelectedDomain)
            .OrderByDescending(x => x.IsBaseObject)
            .ThenBy(x => x.BusinessName)
            .ToList();

        var baseItems = filtered.Where(x => x.IsBaseObject).ToList();
        var derivedItems = filtered.Where(x => !x.IsBaseObject).ToList();

        DisplayObjects.Add(new DisplaySchemaObject
        {
            SchemaObjectId = -1,
            DisplayName = "BASE OBJECTS",
            IsHeader = true
        });

        DisplayObjects.AddRange(baseItems.Select(x => new DisplaySchemaObject
        {
            SchemaObjectId = x.SchemaObjectId,
            DisplayName = GetObjectDisplayName(x),
            IsBaseObject = true
        }));

        if (derivedItems.Any())
        {
            DisplayObjects.Add(new DisplaySchemaObject
            {
                SchemaObjectId = -2,
                DisplayName = "DERIVED VIEWS",
                IsHeader = true
            });

            DisplayObjects.AddRange(derivedItems.Select(x => new DisplaySchemaObject
            {
                SchemaObjectId = x.SchemaObjectId,
                DisplayName = GetObjectDisplayName(x),
                IsBaseObject = false
            }));
        }
    }

    private static string GetObjectDisplayName(SchemaObjectDefinition item)
    {
        if (!string.IsNullOrWhiteSpace(item.BusinessName))
        {
            return item.BusinessName;
        }

        return string.Join(".",
            new[] { item.SourceDatabaseName, item.SourceSchemaName, item.SourceObjectName }
                .Where(part => !string.IsNullOrWhiteSpace(part)));
    }

    private void ResetSelection(bool clearDatabase)
    {
        if (clearDatabase)
        {
            SelectedDatabaseId = null;
            Domains.Clear();
        }

        SelectedDomain = string.Empty;
        SelectedObjectId = null;
        SelectedObject = null;
        DisplayObjects.Clear();
        ParsedTables = new();
        ParsedColumns = new();
        CurrentParsedView = null;
    }

    private void NotifyLoadFailure(string summary, Exception ex)
    {
        LoadError = ex.Message;
        NotificationService.Notify(
            NotificationSeverity.Error,
            summary,
            ex.Message,
            5000);
    }
}
