    AICommandStatus.Pending)]
@attribute [AIChange("1.6", "2026-04-30 03:09 PM CDT restored scrolling on the bounded content card so pages can grow internally while still staying inside the viewport shell.", AICommandStatus.Pending)]
@attribute [AIChange("1.5", "2026-04-30 02:49 PM CDT tightened the shared Radzen body shell so page content stays inside the viewport card and feature pages own their internal scroll regions.", AICommandStatus.Pending)]
