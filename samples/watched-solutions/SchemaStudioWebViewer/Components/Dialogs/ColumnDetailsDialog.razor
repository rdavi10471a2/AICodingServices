@using SchemaStudioWebViewer.Models
@using Radzen
@using Radzen.Blazor

@inject DialogService DialogService

<RadzenStack Gap="1rem" Style="padding: 10px;">
    <RadzenRow>
        <RadzenColumn Size="6">
            <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; text-transform: uppercase;">Physical Name</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="color: #000 !important;">@Column.SourceColumnName</RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; text-transform: uppercase;">Business Name</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1" Style="color: #000 !important; font-weight: 600;">@Column.BusinessName</RadzenText>
        </RadzenColumn>
    </RadzenRow>

    <hr style="border: none; border-top: 1px solid var(--rz-divider);" />

    <div style="max-height: 500px; overflow-y: auto;">
        <RadzenStack Gap="1rem">
            <div>
                <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; text-transform: uppercase;">Description</RadzenText>
                <RadzenTextArea Value="@Column.BusinessDescription" ReadOnly="true"
                                Style="width: 100%; height: 120px; background-color: var(--rz-base-100); color: #000 !important;" />
            </div>

            <div>
                <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; text-transform: uppercase;">Developer Notes</RadzenText>
                <RadzenTextArea Value="@Column.DeveloperNotes" ReadOnly="true"
                                Style="width: 100%; height: 120px; background-color: var(--rz-base-100); color: #000 !important;" />
            </div>
        </RadzenStack>
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="Close" Click="() => DialogService.Close()" Variant="Variant.Flat" />
    </RadzenStack>
</RadzenStack>

@code {
   
    [Parameter] public SchemaObjectColumnModel Column { get; set; } = default!;
}