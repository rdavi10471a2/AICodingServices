    private static List<ExplorerTreeNode> BuildColumnNodes(IEnumerable<ViewSourcedColumnDefinition> columns)
    {
        return columns
            .OrderBy(column => column.OrdinalPosition)
            .Select(column =>
            {
                var node = new ExplorerTreeNode(TreeNodeKind.Column, column.ColumnName)
                {
                    Tooltip = BuildColumnTooltip(column),
                    Expanded = false
                };

                AddDetail(node, "Ordinal", column.OrdinalPosition.ToString());
                AddDetail(node, "Column", column.ColumnName);
                AddDetail(node, "Business Name", column.BusinessName, keepWhenBlank: true);
                AddDetail(node, "Business Description", column.BusinessDescription, keepWhenBlank: true);
                AddDetail(node, "Semantic Source", FormatQualifiedName(column.SemanticDatabase, column.SemanticSchema, column.SemanticObject, column.SemanticColumn));
                AddDetail(node, "Physical Lineage", FormatQualifiedName(column.BaseDatabase, column.BaseSchema, column.BaseTable, column.BaseColumn));
                AddDetail(node, "Inheritance", column.DisableInheritance ? "Disabled for this column" : "Allowed");

                var semanticSource = FormatQualifiedName(column.SemanticDatabase, column.SemanticSchema, column.SemanticObject, column.SemanticColumn);
                if (!string.IsNullOrWhiteSpace(semanticSource))
                {
                    node.Children.Add(new ExplorerTreeNode(TreeNodeKind.Inheritance, semanticSource)
                    {
                        Badge = "Inherits",
                        BadgeClass = "inheritance",
                        Tooltip = semanticSource,
                        Details =
                        {
                            new DetailRow("Ordinal", column.OrdinalPosition.ToString(), GetDetailHelpText("Ordinal")),
                            new DetailRow("Column", column.ColumnName),
                            new DetailRow("Semantic Source", semanticSource, GetDetailHelpText("Semantic Source")),
                            new DetailRow("Inheritance", column.DisableInheritance ? "Disabled" : "Allowed", GetDetailHelpText("Inheritance"))
                        }
                    });
                }

                var physicalLineage = FormatQualifiedName(column.BaseDatabase, column.BaseSchema, column.BaseTable, column.BaseColumn);
                if (!string.IsNullOrWhiteSpace(physicalLineage))
                {
                    node.Children.Add(new ExplorerTreeNode(TreeNodeKind.Lineage, physicalLineage)
                    {
                        Badge = "Lineage",
                        BadgeClass = "lineage",
                        Tooltip = physicalLineage,
                        Details =
                        {
                            new DetailRow("Ordinal", column.OrdinalPosition.ToString(), GetDetailHelpText("Ordinal")),
                            new DetailRow("Column", column.ColumnName),
                            new DetailRow("Physical Lineage", physicalLineage, GetDetailHelpText("Physical Lineage"))
                        }
                    });
                }

                if (node.Children.Count == 0)
                {
                    node.SecondaryText = "no semantic source or physical lineage";
                }

                return node;
            })
            .ToList();
    }

    private static string BuildColumnTooltip(ViewSourcedColumnDefinition column)
    {
        if (!string.IsNullOrWhiteSpace(column.BusinessDescription))
        {
            return string.IsNullOrWhiteSpace(column.BusinessName)
                ? column.BusinessDescription
                : $"{column.BusinessName}: {column.BusinessDescription}";
        }

        if (!string.IsNullOrWhiteSpace(column.BusinessName))
        {
            return column.BusinessName;
        }

        return column.ColumnName;
    }

    private static List<ExplorerTreeNode> BuildSourceNodes(ParsedQuery? query, string selectedViewName)
    {
        if (query == null)
        {
            return new List<ExplorerTreeNode>();
        }

        var children = BuildSourceNodes(query.SourceTables);
        if (children.Count == 0)
        {
            return children;
        }

        var viewIdentity = GetSelectedViewIdentity(query, selectedViewName);
        var root = new ExplorerTreeNode(TreeNodeKind.View, viewIdentity.DisplayName)
        {
            Badge = "View",
            BadgeClass = "inheritance",
            Tooltip = viewIdentity.DisplayName,
            Expanded = true,
            Database = viewIdentity.Database,
            Schema = viewIdentity.Schema,
            ObjectName = viewIdentity.ObjectName
        };

        AddDetail(root, "Object", viewIdentity.DisplayName);
        root.Children.AddRange(children);
        return new List<ExplorerTreeNode> { root };
    }

    private static List<ExplorerTreeNode> BuildSourceNodes(IEnumerable<SourceTable> sources)
    {
        return sources
            .Where(source => source.Kind != SourceKind.DerivedQuery && !string.IsNullOrWhiteSpace(source.Table))
            .OrderBy(source => source.ResolvedOrder)
            .Select(BuildSourceNode)
            .ToList();
    }

    private static ExplorerTreeNode BuildSourceNode(SourceTable source)
    {
        var objectName = FormatQualifiedName(source.Database, source.Schema, source.Table);
        var isCte = source.Kind == SourceKind.Cte;
        var isView = !isCte && source.NestedQuery != null;
        var nodeKind = isCte
            ? TreeNodeKind.Cte
            : isView
                ? TreeNodeKind.View
                : TreeNodeKind.Table;
        var node = new ExplorerTreeNode(nodeKind, objectName)
        {
            Badge = isCte ? "CTE" : isView ? "View" : "Table",
            BadgeClass = isCte ? "cte" : isView ? "inheritance" : string.Empty,
            Tooltip = objectName,
            Expanded = false
        };

        node.Database = source.Database ?? string.Empty;
        node.Schema = source.Schema ?? string.Empty;
        node.ObjectName = source.Table ?? string.Empty;

        AddDetail(node, "Object", objectName);
        AddDetail(node, "Source Type", node.Badge);
        AddDetail(node, "Join Type", source.JoinType);
        AddDetail(node, "Join", source.JoinExpression);

        if (source.NestedQuery != null)
        {
            node.Children.AddRange(BuildSourceNodes(source.NestedQuery.SourceTables));
        }

        return node;
    }

    private static ViewIdentity GetSelectedViewIdentity(ParsedQuery query, string selectedViewName)
    {
        var projectedColumn = query.Columns.FirstOrDefault(column => !string.IsNullOrWhiteSpace(column.Table));
        var database = projectedColumn?.Database ?? string.Empty;
        var schema = projectedColumn?.Schema ?? string.Empty;
        var objectName = projectedColumn?.Table ?? selectedViewName;
        var displayName = FormatQualifiedName(database, schema, objectName);

        if (string.IsNullOrWhiteSpace(displayName))
        {
            displayName = selectedViewName;
        }

        return new ViewIdentity(database, schema, objectName, displayName);
    }

    private static void AddDetail(ExplorerTreeNode node, string label, string? value, bool keepWhenBlank = false)
    {
        if (keepWhenBlank || !string.IsNullOrWhiteSpace(value))
        {
            node.Details.Add(new DetailRow(label, value ?? string.Empty, GetDetailHelpText(label)));
        }
    }

    private static string GetDetailHelpText(string label) =>
        label switch
        {
            "Ordinal" => "The projected sequence of this column in the SELECT list.",
            "Column" => "The column name exposed by the selected view.",
            "Business Name" => "The friendly business label saved or inherited for this column.",
            "Business Description" => "The business definition saved or inherited for this column.",
            "Developer Notes" => "Internal implementation notes saved for this column.",
            "Semantic Source" => "The nearest semantic object and column that define this column's meaning.",
            "Physical Lineage" => "The physical database, schema, table, and column where the data ultimately comes from.",
            "Inheritance" => "Whether semantic metadata inheritance is allowed for this projected column.",
            "Object" => "The fully qualified object selected in the dependency tree.",
            "Source Type" => "Whether this source is a persisted table, a persisted view, or a CTE alias inside the current SQL.",
            "Join Type" => "The SQL join type used for this source object when available.",
            "Join" => "The join expression parsed for this source object when available.",
            _ => string.Empty
        };

    private static string FormatQualifiedName(params string?[] parts) =>
        string.Join(".", parts.Where(part => !string.IsNullOrWhiteSpace(part)));

    private enum TreeNodeKind
    {
        Column,
        Inheritance,
        Lineage,
        View,
        Cte,
        Table
    }

    private sealed class ExplorerTreeNode
    {
        public ExplorerTreeNode(TreeNodeKind kind, string text)
        {
            Kind = kind;
            Text = text;
        }

        public TreeNodeKind Kind { get; }
        public string Text { get; }
        public string SecondaryText { get; set; } = string.Empty;
        public string Badge { get; set; } = string.Empty;
        public string BadgeClass { get; set; } = string.Empty;
        public string Tooltip { get; set; } = string.Empty;
        public bool Expanded { get; set; }
        public string Database { get; set; } = string.Empty;
        public string Schema { get; set; } = string.Empty;
        public string ObjectName { get; set; } = string.Empty;
        public List<ExplorerTreeNode> Children { get; } = new();
        public List<DetailRow> Details { get; init; } = new();
    }

    private sealed record DetailRow(string Label, string Value, string HelpText = "");

    private sealed record SqlViewTab(string Key, string Title, string Content, bool CanClose);

    private sealed record ViewIdentity(string Database, string Schema, string ObjectName, string DisplayName);
}
