@page "/watched-solution"
@inject IWatchedSolutionViewService WatchedSolutionViewService
@inject IWorkspaceStatusService WorkspaceStatusService
@inject SourceNavigationState SourceNavigationState
@inject AICodingServices.Core.DemoWorkspaceService DemoWorkspaceService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Watched Solution</PageTitle>

<section class="source-page">
    <header class="page-header">
        <div class="page-title-row">
            <h1>Watched Solution</h1>
            <span class="page-subtitle">@model.WatchedSolutionPath</span>
        </div>
        <div class="header-actions">
            @if (model.Workspace.RebuildRequired || model.Files.Count == 0)
            {
                <button class="primary-action" type="button" @onclick="RebuildIndexAsync" disabled="@isRebuildingIndex">
                    @(isRebuildingIndex ? "Rebuilding index..." : "Rebuild Index")
                </button>
            }
        </div>
    </header>

    <div class="source-layout">
        <aside class="source-tree" aria-label="Watched source tree">
            <div class="panel-heading">
                <h2>Watched Source</h2>
                <span>@model.Files.Count</span>
            </div>
            <nav class="source-tree-list">
                @foreach (SourceTreeNodeViewModel node in model.Tree)
                {
                    <SourceTreeNode Node="@node" />
                }
            </nav>

            <div class="panel-heading demo-heading">
                <h2>Local Demos</h2>
                <span>@model.DemoFiles.Count</span>
            </div>
            <nav class="source-tree-list demo-tree-list">
                @foreach (SourceTreeNodeViewModel node in model.DemoTree)
                {
                    <SourceTreeNode Node="@node" />
                }
            </nav>
        </aside>

        <section class="source-view">
            @if (model.SelectedFile is null)
            {
                <div class="empty-state">
                    <h2>No File Selected</h2>
                    <p>Select a file to inspect source.</p>
                </div>
            }
            else
            {
                <div class="source-toolbar">
                    <div>
                        <h2>@model.SelectedFile.RelativePath</h2>
                    </div>
                    <div class="source-toolbar-actions">
                        @if (model.IsDemoSelected)
                        {
                            <button class="secondary-action danger-action" type="button" @onclick="DeleteSelectedDemoAsync">Delete</button>
                        }
                        <strong>@model.SelectedFile.Language</strong>
                    </div>
                </div>

                <MonacoSourceEditor File="@model.SelectedFile" />

                <div class="reference-grid">
                    <section class="reference-panel">
                        <div class="panel-heading">
                            <h2>Uses</h2>
                            <span>pending index adapter</span>
                        </div>
                        <p>Read-only source browsing is wired. Symbol reference data will come from the AICodingServices index adapter.</p>
                    </section>
                    <section class="reference-panel">
                        <div class="panel-heading">
                            <h2>Used By</h2>
                            <span>pending index adapter</span>
                        </div>
                        <p>Incoming references will be shown here after the UI consumes the MCP/index surface.</p>
                    </section>
                </div>
            }
        </section>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "path")]
    public string? Path { get; set; }

    [SupplyParameterFromQuery(Name = "line")]
    public int? Line { get; set; }

    [SupplyParameterFromQuery(Name = "demoPath")]
    public string? DemoPath { get; set; }

    private WatchedSolutionViewModel model = WatchedSolutionViewModel.Empty;
    private bool isRebuildingIndex;

    protected override void OnParametersSet()
    {
        RefreshModel();
    }

    private void RefreshModel()
    {
        string? selectedPath = SourceNavigationState.ResolvePath(Path);
        int? selectedLine = SourceNavigationState.ResolveLine(Line);
        model = WatchedSolutionViewService.GetView(selectedPath, selectedLine, DemoPath);
        if (!model.IsDemoSelected)
        {
            SourceNavigationState.Remember(model.SelectedFile?.RelativePath, model.SelectedFile?.SelectedLine);
        }
    }

    private Task DeleteSelectedDemoAsync()
    {
        if (!model.IsDemoSelected || model.SelectedFile is null)
        {
            return Task.CompletedTask;
        }

        DemoWorkspaceService.DeleteDemoFile(model.SelectedFile.RelativePath);
        DemoPath = null;
        RefreshModel();
        NavigationManager.NavigateTo("/watched-solution", replace: true);
        return Task.CompletedTask;
    }

    private async Task RebuildIndexAsync()
    {
        if (isRebuildingIndex)
        {
            return;
        }

        isRebuildingIndex = true;
        try
        {
            await WorkspaceStatusService.RebuildIndexAsync(CancellationToken.None);
            RefreshModel();
        }
        finally
        {
            isRebuildingIndex = false;
        }
    }
}
