@page "/"
@rendermode InteractiveServer

<PageTitle>Coding Services</PageTitle>

<section class="overview-page">
    <RadzenStack Gap="1rem">
        <RadzenCard class="overview-hero">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="solution-title-row">
                    <RadzenText TextStyle="TextStyle.H1" class="overview-title">@model.Title</RadzenText>
                    <RadzenStack Gap="0.2rem" class="observed-solution">
                        <span class="observing-label">(observing)</span>
                        <RadzenText class="target-path">@model.WatchedSolutionPath</RadzenText>
                    </RadzenStack>
                </RadzenStack>
                <RadzenBadge BadgeStyle="@McpBadgeStyle" Text="@McpStatusLabel" class="status-badge" />
            </RadzenStack>
        </RadzenCard>

        <RadzenCard class="index-panel">
            <RadzenStack Gap="1rem">
                <div class="index-header">
                    <div>
                        <RadzenText TextStyle="TextStyle.H2" class="section-title">Solution Index Details</RadzenText>
                    </div>
                    <div class="index-actions">
                        @if (model.Workspace.RebuildRequired)
                        {
                            <RadzenButton Text="@IndexActionLabel" ButtonStyle="ButtonStyle.Primary" Click="RebuildIndexAsync" Disabled="@isRebuildingIndex" />
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="@IndexBadgeStyle" Text="@IndexStatusLabel" class="status-badge" />
                        }
                    </div>
                </div>

                @if (model.Workspace.RebuildRequired)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                        @model.Workspace.IndexLabel
                    </RadzenAlert>
                }

                <div class="index-summary-grid">
                    <div class="index-metric">
                        <span>Projects</span>
                        <strong>@model.Workspace.ProjectCount</strong>
                    </div>
                    <div class="index-metric">
                        <span>Documents</span>
                        <strong>@model.Workspace.DocumentCount</strong>
                    </div>
                    <div class="index-metric">
                        <span>Symbols</span>
                        <strong>@model.Workspace.SymbolCount.ToString("N0")</strong>
                    </div>
                    <div class="index-metric">
                        <span>References</span>
                        <strong>@model.Workspace.ReferenceCount.ToString("N0")</strong>
                    </div>
                    <div class="index-metric">
                        <span>Call Sites</span>
                        <strong>@model.Workspace.CallSiteCount.ToString("N0")</strong>
                    </div>
                </div>

                <div class="index-detail-grid">
                    <div class="detail-tile">
                        <span>Diagnostics</span>
                        <strong>0</strong>
                    </div>
                    <div class="detail-tile">
                        <span>Stale Items</span>
                        <strong>0</strong>
                    </div>
                    <div class="detail-tile detail-tile-wide">
                        <span>Last Build</span>
                        <strong>@model.Workspace.LastBuildLabel</strong>
                    </div>
                </div>
            </RadzenStack>
        </RadzenCard>

        <RadzenCard class="usage-panel">
            <RadzenStack Gap="1rem">
                <div class="index-header">
                    <div>
                        <RadzenText TextStyle="TextStyle.H2" class="section-title">Codex Usage</RadzenText>
                        <p class="panel-subtitle">Aggregate counters from local Codex logs</p>
                    </div>
                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@model.CodexUsage.State" class="status-badge" />
                </div>

                <div class="usage-balance-grid">
                    <div class="usage-balance-card">
                        <span>5 hour usage limit</span>
                        <strong>@model.CodexUsage.FiveHourLabel</strong>
                        <div class="usage-progress">
                            <div style="@GetUsageProgressStyle(model.CodexUsage.FiveHourRemainingPercent)"></div>
                        </div>
                        <small>Resets @model.CodexUsage.FiveHourResetLabel</small>
                    </div>
                    <div class="usage-balance-card">
                        <span>Weekly usage limit</span>
                        <strong>@model.CodexUsage.WeeklyLabel</strong>
                        <div class="usage-progress">
                            <div style="@GetUsageProgressStyle(model.CodexUsage.WeeklyRemainingPercent)"></div>
                        </div>
                        <small>Resets @model.CodexUsage.WeeklyResetLabel</small>
                    </div>
                </div>

                <div class="usage-split-grid">
                    <div class="usage-section">
                        <div class="usage-section-header">
                            <RadzenText TextStyle="TextStyle.H3" class="usage-section-title">Last Turn</RadzenText>
                            <strong>@model.CodexUsage.LastTurnTokens.ToString("N0")</strong>
                        </div>
                        <div class="usage-mini-grid">
                            <div>
                                <span>Fresh Input</span>
                                <strong>@model.CodexUsage.LastTurnFreshInputTokens.ToString("N0")</strong>
                            </div>
                            <div>
                                <span>Cached Input</span>
                                <strong>@model.CodexUsage.LastTurnCachedInputTokens.ToString("N0")</strong>
                            </div>
                            <div>
                                <span>Output</span>
                                <strong>@model.CodexUsage.LastTurnOutputTokens.ToString("N0")</strong>
                            </div>
                            <div>
                                <span>Reasoning</span>
                                <strong>@model.CodexUsage.LastTurnReasoningOutputTokens.ToString("N0")</strong>
                            </div>
                        </div>
                    </div>

                    <div class="usage-section">
                        <div class="usage-section-header">
                            <RadzenText TextStyle="TextStyle.H3" class="usage-section-title">Scanned Window</RadzenText>
                            <strong>@model.CodexUsage.SessionSpanLabel</strong>
                        </div>
                        <div class="usage-mini-grid">
                            <div>
                                <span>Started</span>
                                <strong>@model.CodexUsage.FirstUsageLabel</strong>
                            </div>
                            <div>
                                <span>Last Usage</span>
                                <strong>@model.CodexUsage.LastUsageLabel</strong>
                            </div>
                            <div>
                                <span>Events</span>
                                <strong>@model.CodexUsage.UsageEventCount.ToString("N0")</strong>
                            </div>
                            <div>
                                <span>Recent Files</span>
                                <strong>@model.CodexUsage.SessionFileCount.ToString("N0")</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="usage-detail-grid">
                    <div class="detail-tile">
                        <span>Total Tokens</span>
                        <strong>@model.CodexUsage.TotalTokens.ToString("N0")</strong>
                    </div>
                    <div class="detail-tile">
                        <span>Fresh Input</span>
                        <strong>@model.CodexUsage.FreshInputTokens.ToString("N0")</strong>
                    </div>
                    <div class="detail-tile">
                        <span>Cached Input</span>
                        <strong>@model.CodexUsage.CachedInputTokens.ToString("N0")</strong>
                    </div>
                    <div class="detail-tile">
                        <span>Output</span>
                        <strong>@model.CodexUsage.OutputTokens.ToString("N0")</strong>
                    </div>
                </div>
            </RadzenStack>
        </RadzenCard>

        @if (!string.IsNullOrWhiteSpace(rebuildMessage))
        {
            <RadzenAlert AlertStyle="@rebuildAlertStyle" ShowIcon="true" Variant="Variant.Flat">
                @rebuildMessage
            </RadzenAlert>
        }
    </RadzenStack>
</section>
